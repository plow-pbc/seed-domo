#!/usr/bin/env bash
#
# domo — Domo orchestrator CLI
#
# Domo is a channels-only, host-raw, subscription-billed household assistant. It runs
# as ONE persistent `claude --channels` session in Claude Code "auto mode". This CLI
# bootstraps that session, runs the Plow Chat activation handshake, and runs the
# session either in the FOREGROUND (`shell`, interactive — for one-time consent/login)
# or as a detached BACKGROUND daemon (`start`/`stop`/`status`/`logs`). shell and start
# share ONE pinned session UUID so they are a single continuous conversation.
#
# Authoritative design: ../PLAN.md and the build contract that produced this file.
#
# Permission posture: `--permission-mode auto` (classifier-gated). No custom PreToolUse
# allowlist (that was intentionally removed — do NOT reintroduce it). bypassPermissions
# is reachable via DOMO_PERMISSION_MODE but is NOT the default.
#
# Channel selector: DOMO_CHANNEL=plow-chat (default) | fakechat. plow-chat loads the
# LOCAL plugin dir via --plugin-dir and reads its Bearer token from a chmod-600 state
# file (path via PLOW_CHAT_STATE). fakechat keeps the marketplace-install path from the
# legacy run.sh for local testing with no Plow activation.
#
# Subcommands:
#   setup     idempotent bootstrap (dirs + workspace + session UUID + channel loadable)
#   activate  Plow handshake in bash+curl -> chmod-600 state file (plow-chat only)
#   shell     run the session in the FOREGROUND (interactive; one-time consent/login)
#   start     run the SAME session in the BACKGROUND, detached (PID file + logfile)
#   stop      kill the daemon by PID file + sweep stray channel child
#   status    resolved config + daemon liveness + channel state (no secrets)
#   logs      tail the daemon logfile
#   doctor    read-only preflight
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Source-of-truth paths
# ---------------------------------------------------------------------------

# REPO_ROOT is resolved from this script's own location so the build is portable.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR"

# DOMO_HOME is the isolated Claude home for this instance. Defaults to THIS checkout,
# so Domo's config / auth / sessions / plugins / channel state live entirely inside
# the project (under .claude/, which is gitignored). Override to relocate (e.g. ~/domo).
DOMO_HOME="${DOMO_HOME:-$REPO_ROOT}"
CONFIG_DIR="$DOMO_HOME/.claude"
WORKSPACE="$DOMO_HOME/workspace"

# Daemon runtime (gitignored).
RUN_DIR="$CONFIG_DIR/run"
LOG_FILE="$RUN_DIR/domo.log"
PID_FILE="$RUN_DIR/domo.pid"
# Records the launched claude argv signature so `stop` can tree-kill the real
# claude process when the PID file points at the `script` PTY wrapper (see #1).
SIG_FILE="$RUN_DIR/domo.sig"

# Domo metadata (gitignored): holds the pinned session UUID.
META_FILE="$CONFIG_DIR/domo.json"

# Optional gitignored token/env, sourced if present (headless subscription auth).
ENV_FILE="$DOMO_HOME/.env"
TOKEN_FILE="$CONFIG_DIR/oauth-token"

# Channel selection. Default plow-chat (the real surface); fakechat is the local
# test alternate that needs no Plow activation.
DOMO_CHANNEL="${DOMO_CHANNEL:-plow-chat}"

# --- plow-chat paths ---
PLOW_DIR="$CONFIG_DIR/plow-chat"                 # chmod-700 dir holding secrets
PLOW_STATE_FILE="$PLOW_DIR/state.json"           # redeemed {base_url,token,chat_uid}
PLOW_ACTIVATION_FILE="$PLOW_DIR/activation.json" # transient pre-token secret
PLOW_CHANNEL_DIR="$REPO_ROOT/channels/plow-chat" # local plugin dir (--plugin-dir)
PLOW_BASE_URL="${PLOW_CHAT_BASE_URL:-https://api.plow.co}"

# --- fakechat (marketplace) config, carried from run.sh ---
MARKETPLACE_SRC="anthropics/claude-plugins-official"
FAKECHAT_PLUGIN_SPEC="fakechat@claude-plugins-official"
FAKECHAT_CHANNELS_FLAG="plugin:fakechat@claude-plugins-official"
FAKECHAT_PORT="${FAKECHAT_PORT:-8787}"

# Permission posture for the persistent session (carried from run.sh).
PERMISSION_MODE="${DOMO_PERMISSION_MODE:-auto}"

# Workspace project-dir slug: claude slugs the CWD by replacing every '/' and '.'
# with '-'. start/shell cd into $WORKSPACE before exec, so the project dir is the
# WORKSPACE slug (verified layout in $CONFIG_DIR/projects).
WORKSPACE_SLUG="$(printf '%s' "$WORKSPACE" | sed 's/[\/.]/-/g')"
PROJECTS_DIR="$CONFIG_DIR/projects/$WORKSPACE_SLUG"

# ---------------------------------------------------------------------------
# Small helpers
# ---------------------------------------------------------------------------
log()  { printf '[domo] %s\n' "$*" >&2; }
warn() { printf '[domo] WARNING: %s\n' "$*" >&2; }
die()  { printf '[domo] ERROR: %s\n' "$*" >&2; exit 1; }

# Export the isolated config dir — scopes plugins/connectors/sessions/auth/channel
# state to the Domo instance. MUST be exported in every subcommand that launches claude.
export_config_dir() {
  export CLAUDE_CONFIG_DIR="$CONFIG_DIR"
  log "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR"
}

require_claude() {
  command -v claude >/dev/null 2>&1 || die "the 'claude' CLI is not on PATH. Install Claude Code first."
}

require_bun() {
  command -v bun >/dev/null 2>&1 || die "the 'bun' runtime is not on PATH (needed for the plow-chat channel)."
}

require_curl() {
  command -v curl >/dev/null 2>&1 || die "'curl' is not on PATH (needed for ./domo activate)."
}

# Resolve subscription auth. The token is OPTIONAL:
#   1. CLAUDE_CODE_OAUTH_TOKEN (env, then $ENV_FILE, then $TOKEN_FILE) — headless path.
#   2. Otherwise the interactive login stored in the isolated config dir (/login).
# NON-FATAL: never blocks start/shell. Always unsets ANTHROPIC_API_KEY (subscription).
ensure_auth() {
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" && -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    set +u; source "$ENV_FILE"; set -u
  fi
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" && -f "$TOKEN_FILE" ]]; then
    CLAUDE_CODE_OAUTH_TOKEN="$(tr -d '[:space:]' < "$TOKEN_FILE")"
  fi
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
    export CLAUDE_CODE_OAUTH_TOKEN
    log "Auth: using CLAUDE_CODE_OAUTH_TOKEN (headless subscription token)."
  else
    log "Auth: no token set — using the interactive login in $CONFIG_DIR."
    log "      If this instance isn't logged in yet, run './domo shell' and '/login' once."
  fi
  # Keep subscription auth; never silently fall back to metered API billing.
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    warn "ANTHROPIC_API_KEY is set; unsetting it so subscription auth is used."
    unset ANTHROPIC_API_KEY
  fi
}

# fakechat's bun server can outlive the claude session and keep holding FAKECHAT_PORT,
# which makes the NEXT start show 'fakechat: failed'. Free the port if a stale fakechat
# (`bun … server.ts`) holds it; warn (but don't kill) if some OTHER process holds it.
free_fakechat_port() {
  command -v lsof >/dev/null 2>&1 || return 0
  local pids pid cmd
  pids="$(lsof -nP -tiTCP:"$FAKECHAT_PORT" -sTCP:LISTEN 2>/dev/null || true)"
  for pid in $pids; do
    cmd="$(ps -o command= -p "$pid" 2>/dev/null || true)"
    if printf '%s' "$cmd" | grep -q 'server\.ts'; then
      warn "Freeing port $FAKECHAT_PORT: killing stale fakechat server (pid $pid)."
      kill "$pid" 2>/dev/null || true
      sleep 1
    else
      warn "Port $FAKECHAT_PORT is held by a non-fakechat process (pid $pid: ${cmd%% *})."
      warn "fakechat will fail to bind — pick a free port: FAKECHAT_PORT=<n> ./domo start"
    fi
  done
}

# Read a top-level string field from a small JSON file using bun (already a hard dep
# of the channel). Echoes the value (empty if missing/unparseable). NEVER used for
# the token in any path that prints.
json_get() { # json_get <file> <field>
  local file="$1" field="$2"
  [[ -f "$file" ]] || { printf ''; return 0; }
  bun -e '
    // NOTE: under `bun -e`, process.argv = [bunPath, ...userArgs] (no script slot),
    // so user args start at index 1. Slice(1) normalizes to a 0-based list.
    const A = process.argv.slice(1);
    const [file, field] = [A[0], A[1]];
    try {
      const o = JSON.parse(require("fs").readFileSync(file, "utf8"));
      const v = o?.[field];
      process.stdout.write(v == null ? "" : String(v));
    } catch { process.stdout.write(""); }
  ' "$file" "$field" 2>/dev/null || printf ''
}

# ---------------------------------------------------------------------------
# Session pinning — one UUID shared by shell and start (ONE continuous session).
# ---------------------------------------------------------------------------

# Read the pinned session UUID from domo.json (empty if none yet).
read_session_id() { json_get "$META_FILE" "session_id"; }

# Write/refresh domo.json with the given session_id (atomic; umask 077).
# Preserves any EXISTING `created` and `channel` so a fallback re-persist (or a
# run under a different DOMO_CHANNEL) does not silently rewrite the pinned
# session's original metadata; only fills them in when absent (#12).
write_meta() { # write_meta <session_id>
  local sid="$1" iso
  iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mkdir -p "$CONFIG_DIR"
  local tmp; tmp="$(umask 077; mktemp "$CONFIG_DIR/.domo.json.XXXXXX")"
  META_FILE="$META_FILE" DOMO_CHANNEL="$DOMO_CHANNEL" bun -e '
    // `bun -e` argv has no script slot; user args start at index 1.
    const [out, sid, iso] = process.argv.slice(1);
    const fs = require("fs");
    let prev = {};
    try { prev = JSON.parse(fs.readFileSync(process.env.META_FILE, "utf8")); } catch {}
    fs.writeFileSync(out, JSON.stringify({
      session_id: sid,
      // created/channel are advisory; keep the originals if present.
      channel: prev.channel ?? process.env.DOMO_CHANNEL,
      created: prev.created ?? iso,
    }, null, 2) + "\n");
  ' "$tmp" "$sid" "$iso"
  chmod 600 "$tmp"
  mv -f "$tmp" "$META_FILE"
}

# Resolve the launch session flag pair into the global array SESSION_FLAG[].
#
# FIRST-RUN DETECTION: a session already exists iff its jsonl is on disk under the
# WORKSPACE project dir. If absent -> first run -> --session-id <uuid>. If present ->
# resume -> --resume <uuid>. Both shell and start call this so they agree.
#
# ⚠️ COMPOSE-VERIFICATION (runtime-unverifiable here): --session-id/--resume are each
# confirmed present in `claude --help` but their composition with --channels is not
# verified in this build. If they DON'T compose, the documented fallback is:
# launch WITHOUT --session-id on first run, then on later starts resume the LATEST
# jsonl by mtime under the workspace project dir and persist that id back to domo.json.
# Set DOMO_SESSION_FALLBACK=1 to take that path.
SESSION_FLAG=()
resolve_session_flag() {
  local sid; sid="$(read_session_id)"
  [[ -n "$sid" ]] || die "no session_id in $META_FILE — run './domo setup' first."

  local session_file="$PROJECTS_DIR/$sid.jsonl"

  if [[ "${DOMO_SESSION_FALLBACK:-0}" == "1" ]]; then
    # Escape-hatch path: don't pin a UUID; resume the latest jsonl by mtime.
    local latest
    latest="$(ls -t "$PROJECTS_DIR"/*.jsonl 2>/dev/null | head -1 || true)"
    if [[ -n "$latest" ]]; then
      local found; found="$(basename "$latest" .jsonl)"
      write_meta "$found" # persist discovered id so future runs are deterministic
      SESSION_FLAG=(--resume "$found")
      log "Session (fallback): --resume $found (latest jsonl by mtime)."
    else
      SESSION_FLAG=() # let claude create a fresh jsonl on first run
      log "Session (fallback): no jsonl yet; launching without a session flag (claude creates one)."
    fi
    return 0
  fi

  if [[ -f "$session_file" ]]; then
    SESSION_FLAG=(--resume "$sid")
    log "Session: --resume $sid (existing jsonl found)."
  else
    SESSION_FLAG=(--session-id "$sid")
    log "Session: --session-id $sid (first run; no jsonl yet)."
  fi
}

# ---------------------------------------------------------------------------
# Channel argv assembly — builds the global arrays CHANNEL_ARGS[] (claude flags)
# and sets per-channel env. Mirrors run.sh's CHANNELS_FLAG handling, generalized.
# ---------------------------------------------------------------------------
CHANNEL_ARGS=()
CHANNELS_FLAG=""
PLUGIN_DIR=""
prepare_channel_env() {
  case "$DOMO_CHANNEL" in
    plow-chat)
      # plow-chat is a CUSTOM channel (not on the research-preview allowlist), so it
      # loads via --dangerously-load-development-channels server:<name>, NOT --channels
      # / --plugin-dir. The MCP server named 'plow-chat' is registered by `domo setup`
      # (claude mcp add), so the `server:` form resolves. (cite channels-reference.md.)
      CHANNELS_FLAG="server:plow-chat"
      # The server reads its secrets from this absolute path (mirrors FAKECHAT_PORT).
      export PLOW_CHAT_STATE="$PLOW_STATE_FILE"
      CHANNEL_ARGS=(--dangerously-load-development-channels "$CHANNELS_FLAG")
      log "Channel: plow-chat (dev channel server:plow-chat); PLOW_CHAT_STATE=$PLOW_CHAT_STATE"
      [[ -f "$PLOW_STATE_FILE" ]] || warn "plow-chat state.json missing — run './domo activate' (the channel loads but reply errors until then)."
      ;;
    fakechat)
      CHANNELS_FLAG="$FAKECHAT_CHANNELS_FLAG"
      PLUGIN_DIR=""
      export FAKECHAT_PORT
      free_fakechat_port
      CHANNEL_ARGS=(--channels "$CHANNELS_FLAG")
      log "Channel: fakechat (marketplace); FAKECHAT_PORT=$FAKECHAT_PORT  UI http://localhost:$FAKECHAT_PORT"
      ;;
    *)
      die "unknown DOMO_CHANNEL='$DOMO_CHANNEL' (expected plow-chat | fakechat)."
      ;;
  esac
}

# Build the full claude argv into the global array CLAUDE_ARGV[]. shell and start
# call this so they launch the IDENTICAL command (one continuous pinned session).
CLAUDE_ARGV=()
build_claude_argv() {
  prepare_channel_env
  resolve_session_flag
  CLAUDE_ARGV=(claude "${CHANNEL_ARGS[@]}" --permission-mode "$PERMISSION_MODE")
  if [[ ${#SESSION_FLAG[@]} -gt 0 ]]; then
    CLAUDE_ARGV+=("${SESSION_FLAG[@]}")
  fi
}

# ---------------------------------------------------------------------------
# setup — idempotent bootstrap
# ---------------------------------------------------------------------------
cmd_setup() {
  export_config_dir
  require_claude

  log "Creating isolated dirs..."
  mkdir -p "$CONFIG_DIR" "$WORKSPACE" "$RUN_DIR"
  mkdir -p "$PLOW_DIR"; chmod 700 "$PLOW_DIR"

  # Generate + persist the pinned session UUID if domo.json has none.
  local sid; sid="$(read_session_id)"
  if [[ -z "$sid" ]]; then
    command -v uuidgen >/dev/null 2>&1 || die "uuidgen not found (needed to mint the session UUID)."
    sid="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    write_meta "$sid"
    log "Generated session UUID: $sid (stored in $META_FILE)."
  else
    log "Session UUID already present: $sid."
  fi

  # Ensure the selected channel is loadable.
  case "$DOMO_CHANNEL" in
    plow-chat)
      require_bun
      local missing=0
      for f in "$PLOW_CHANNEL_DIR/.claude-plugin/plugin.json" "$PLOW_CHANNEL_DIR/.mcp.json" "$PLOW_CHANNEL_DIR/server.ts"; do
        if [[ -f "$f" ]]; then log "OK   channel file present: $f"; else warn "MISS channel file absent: $f"; missing=1; fi
      done
      [[ "$missing" -eq 0 ]] || die "plow-chat channel dir incomplete at $PLOW_CHANNEL_DIR."
      # Register plow-chat as a manually-configured MCP server so `server:plow-chat`
      # resolves for --dangerously-load-development-channels (NOT --plugin-dir). The
      # spawned server inherits PLOW_CHAT_STATE from the env domo exports at launch.
      # Use the absolute channel dir (no ${CLAUDE_PLUGIN_ROOT}, which is plugin-only).
      log "Registering MCP server 'plow-chat' (user scope) -> bun start in $PLOW_CHANNEL_DIR ..."
      claude mcp remove plow-chat </dev/null >/dev/null 2>&1 || true   # idempotent: drop any stale registration
      if claude mcp add plow-chat --scope user -- \
           bun run --cwd "$PLOW_CHANNEL_DIR" --shell=bun --silent start </dev/null; then
        log "OK   plow-chat MCP server registered."
      else
        warn "claude mcp add plow-chat returned non-zero — check 'claude mcp list'."
      fi
      log "plow-chat loads via --dangerously-load-development-channels server:plow-chat."
      ;;
    fakechat)
      ensure_auth
      log "Adding marketplace '$MARKETPLACE_SRC' (user scope)..."
      claude plugin marketplace add "$MARKETPLACE_SRC" </dev/null >/dev/null 2>&1 \
        || warn "marketplace add returned non-zero (may already exist). Continuing."
      log "Installing plugin '$FAKECHAT_PLUGIN_SPEC' (user scope)..."
      if claude plugin install "$FAKECHAT_PLUGIN_SPEC" --scope user </dev/null; then
        log "fakechat installed."
      else
        warn "plugin install returned non-zero (may already be installed, or needs /login first)."
      fi
      ;;
    *) die "unknown DOMO_CHANNEL='$DOMO_CHANNEL'." ;;
  esac

  cat >&2 <<EOF

[domo] ============================================================
[domo] REMAINING ONE-TIME INTERACTIVE STEPS
[domo] ============================================================
[domo]
[domo] A) Connect Google Calendar ONCE at the ACCOUNT level (browser):
[domo]      https://claude.ai/customize/connectors -> Google Calendar -> Connect
[domo]    Use the SAME Anthropic account you'll /login below.
[domo]
[domo] B) Log this instance in (and accept the one-time channels-preview consent):
[domo]      ./domo shell        # interactive claude under CLAUDE_CONFIG_DIR=$CONFIG_DIR
[domo]      /login              # SAME account that holds the Calendar connector; then exit
[domo]
[domo] C) (plow-chat only) Activate the Plow line + chat:
[domo]      ./domo activate     # prints a code to text; writes the chmod-600 state file
[domo]
[domo] Then:  ./domo doctor    and    ./domo start   (background daemon)
[domo] ============================================================
EOF
  log "Setup complete (channel=$DOMO_CHANNEL)."
}

# ---------------------------------------------------------------------------
# activate — Plow handshake (bash + curl only; plow-chat). Writes chmod-600 state.
# ---------------------------------------------------------------------------
cmd_activate() {
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] || die "activate is only for DOMO_CHANNEL=plow-chat (current: $DOMO_CHANNEL)."
  require_curl
  require_bun

  mkdir -p "$PLOW_DIR"; chmod 700 "$PLOW_DIR"

  # Idempotent-ish: if state.json already has a token, stop unless --force.
  if [[ "$force" -eq 0 && -f "$PLOW_STATE_FILE" ]]; then
    local existing; existing="$(json_get "$PLOW_STATE_FILE" "token")"
    if [[ -n "$existing" ]]; then
      log "already activated (state.json has a token). Use './domo activate --force' to redo."
      return 0
    fi
  fi

  # --- Step 1: POST /v1/auth/activate {name, provision_chat:true} ---
  log "Requesting Plow activation at $PLOW_BASE_URL ..."
  local resp1
  resp1="$(curl -fsS -X POST "$PLOW_BASE_URL/v1/auth/activate" \
    -H 'Content-Type: application/json' \
    --data '{"name":"Domo","provision_chat":true}')" \
    || die "activation request failed (POST /v1/auth/activate). Check connectivity."

  # Parse with bun (no python). Pull the four fields we need.
  local activation_secret display_code send_to line_id
  activation_secret="$(printf '%s' "$resp1" | bun -e 'const s=require("fs").readFileSync(0,"utf8");process.stdout.write(String(JSON.parse(s).activation_secret??""))')"
  display_code="$(printf '%s' "$resp1" | bun -e 'const s=require("fs").readFileSync(0,"utf8");process.stdout.write(String(JSON.parse(s).display_code??""))')"
  send_to="$(printf '%s' "$resp1" | bun -e 'const s=require("fs").readFileSync(0,"utf8");process.stdout.write(String(JSON.parse(s).send_to??""))')"
  # Read both spellings defensively (line_id per the contract example, line_uid as
  # an alternate) so either Plow field name works (#4; runtime-unverified).
  line_id="$(printf '%s' "$resp1" | bun -e 'const o=JSON.parse(require("fs").readFileSync(0,"utf8"));process.stdout.write(String(o.line_id??o.line_uid??""))')"

  [[ -n "$activation_secret" ]] || die "activation response missing activation_secret."
  [[ -n "$display_code" && -n "$send_to" ]] || die "activation response missing display_code/send_to."

  # Persist the transient pre-token secret to a SEPARATE chmod-600 file so a
  # half-finished activation never looks like usable state.
  local tmp; tmp="$(umask 077; mktemp "$PLOW_DIR/.activation.json.XXXXXX")"
  printf '%s' "$resp1" | bun -e '
    const s = require("fs").readFileSync(0, "utf8");
    const a = JSON.parse(s);
    // `bun -e` argv has no script slot; user args start at index 1.
    const A = process.argv.slice(1);
    const out = A[0];
    require("fs").writeFileSync(out, JSON.stringify({
      base_url: A[1],
      activation_secret: a.activation_secret,
      display_code: a.display_code,
      send_to: a.send_to,
      line_uid: a.line_id ?? a.line_uid ?? null,
    }, null, 2) + "\n");
  ' "$tmp" "$PLOW_BASE_URL"
  chmod 600 "$tmp"; mv -f "$tmp" "$PLOW_ACTIVATION_FILE"

  cat >&2 <<EOF

[domo] ============================================================
[domo] PLOW ACTIVATION — ACTION REQUIRED
[domo] ============================================================
[domo] From the phone you want bound to this chat, text EXACTLY:
[domo]
[domo]     Plow Activate: $display_code
[domo]
[domo]   to:  $send_to
[domo]
[domo] (line: ${line_id:-unknown})  Polling for verification (up to ~5 min)...
[domo] ============================================================
EOF

  # --- Step 2: poll POST /v1/auth/activate/redeem until verified (cap ~5min) ---
  local deadline=$(( $(date +%s) + 300 ))
  local status="pending" redeem token chat_uid
  while :; do
    # Pass the pre-token activation_secret via STDIN, never argv, so it is not
    # visible to other local users via `ps` during the ~5-min poll (#3).
    redeem="$(printf '{"activation_secret":"%s"}' "$activation_secret" \
      | curl -fsS -X POST "$PLOW_BASE_URL/v1/auth/activate/redeem" \
        -H 'Content-Type: application/json' \
        --data-binary @- 2>/dev/null || true)"
    if [[ -n "$redeem" ]]; then
      status="$(printf '%s' "$redeem" | bun -e 'try{const s=require("fs").readFileSync(0,"utf8");process.stdout.write(String(JSON.parse(s).status??"pending"))}catch{process.stdout.write("pending")}')"
    fi
    if [[ "$status" == "verified" ]]; then break; fi
    if [[ "$(date +%s)" -ge "$deadline" ]]; then
      die "activation not verified within ~5 min. Re-run './domo activate' once you've texted the code."
    fi
    sleep 3
  done

  # Extract token + chat.uid from the verified redeem response.
  token="$(printf '%s' "$redeem" | bun -e 'const s=require("fs").readFileSync(0,"utf8");process.stdout.write(String(JSON.parse(s).token??""))')"
  chat_uid="$(printf '%s' "$redeem" | bun -e 'const s=require("fs").readFileSync(0,"utf8");const o=JSON.parse(s);process.stdout.write(String((o.chat&&o.chat.uid)||""))')"
  [[ -n "$token" ]] || die "verified redeem response had no token."
  [[ -n "$chat_uid" ]] || die "verified redeem response had no chat.uid."

  # Write redeemed state atomically (umask 077; temp + mv). Build JSON via bun so the
  # token is never interpolated into a shell-visible command line.
  local stmp; stmp="$(umask 077; mktemp "$PLOW_DIR/.state.json.XXXXXX")"
  TOKEN="$token" CHAT_UID="$chat_uid" BASE_URL="$PLOW_BASE_URL" bun -e '
    // `bun -e` argv has no script slot; user args start at index 1.
    const out = process.argv.slice(1)[0];
    require("fs").writeFileSync(out, JSON.stringify({
      base_url: process.env.BASE_URL.replace(/\/$/, ""),
      token: process.env.TOKEN,
      chat_uid: process.env.CHAT_UID,
    }, null, 2) + "\n");
  ' "$stmp"
  chmod 600 "$stmp"; mv -f "$stmp" "$PLOW_STATE_FILE"

  # The activation_secret is spent; delete the transient file.
  rm -f "$PLOW_ACTIVATION_FILE"

  log "Activation verified. State written to $PLOW_STATE_FILE (chmod 600). chat_uid=$chat_uid"
  log "Token stored (NOT printed). If a session is already running: './domo stop && ./domo start' to pick it up."
}

# ---------------------------------------------------------------------------
# shell — FOREGROUND interactive session (one-time consent / /login / debugging).
# Uses the SAME launch argv as start so they share ONE pinned session.
# ---------------------------------------------------------------------------
cmd_shell() {
  export_config_dir
  require_claude
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] && require_bun
  ensure_auth
  [[ -d "$WORKSPACE" ]] || mkdir -p "$WORKSPACE"
  cd "$WORKSPACE" # cd BEFORE building argv so the workspace project-dir slug is correct
  build_claude_argv
  log "Opening FOREGROUND session in $WORKSPACE (CLAUDE_CONFIG_DIR=$CONFIG_DIR)."
  log "One-time here: accept channels-preview consent + '/login'. Then exit."
  log "Launch: ${CLAUDE_ARGV[*]}"
  exec "${CLAUDE_ARGV[@]}"
}

# Compute a pkill -f pattern that uniquely identifies THIS instance's claude
# process. The pinned session UUID is the tightest signature — it appears in the
# argv as `--session-id <uuid>` / `--resume <uuid>` and is unique per instance, so
# two Domo instances under different DOMO_HOME never reap each other. Fall back to
# the channel signature only if no pinned UUID is in use (e.g. DOMO_SESSION_FALLBACK).
daemon_kill_pattern() {
  local sid; sid="$(read_session_id)"
  if [[ -n "$sid" ]]; then printf '%s' "$sid"; return; fi
  case "$DOMO_CHANNEL" in
    plow-chat) printf '%s' "server:plow-chat" ;;
    fakechat)  printf '%s' "$FAKECHAT_CHANNELS_FLAG" ;;
    *)         printf '%s' "$WORKSPACE" ;;
  esac
}

# Persist the kill pattern at start so stop can reap the real claude even if the
# recorded PID is the `script` wrapper.
write_daemon_sig() {
  mkdir -p "$RUN_DIR"
  local tmp; tmp="$(umask 077; mktemp "$RUN_DIR/.domo.sig.XXXXXX")"
  printf '%s\n' "$(daemon_kill_pattern)" > "$tmp"
  mv -f "$tmp" "$SIG_FILE"
}

# ---------------------------------------------------------------------------
# start — BACKGROUND detached daemon. Same session as shell. PID file + logfile.
#
# ⚠️ HEADLESS-SURVIVAL (verify-at-runtime): an interactive `claude --channels` may
# exit on stdin EOF when backgrounded. macOS has NO setsid (verified), but `script`
# IS at /usr/bin/script. So we give claude a controlling PTY via:
#     script -q -F -e /dev/null claude … </dev/null >>LOG 2>&1 &
# (-q quiet, -F flush so logs stream, -e pass through child exit status; file arg is
# /dev/null so no typescript is kept; the rest is the command). This needs no tmux.
# VERIFY at runtime that the session stays alive after the launching shell exits and
# that channel events still flow; if `script` mishandles it, fall back to a
# foreground `./domo shell` under a user-run tmux / launchd KeepAlive. Documented,
# not blocking. Override the wrapper entirely with DOMO_NO_PTY=1 (plain background).
# ---------------------------------------------------------------------------
cmd_start() {
  export_config_dir
  require_claude
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] && require_bun
  ensure_auth

  [[ -d "$WORKSPACE" ]] || die "workspace not found at $WORKSPACE. Run './domo setup' first."

  # Refuse if a live daemon is already recorded. Check BOTH the recorded pid AND
  # the scoped argv signature: under the PTY path the wrapper pid may have exited
  # while the orphaned claude survives (#1), so a pid-only check would wrongly
  # allow a second claude. We must cd into WORKSPACE-independent scope here, so
  # compute the signature directly.
  local sig; sig="$(daemon_kill_pattern)"
  if [[ -f "$PID_FILE" ]]; then
    local oldpid; oldpid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
      die "daemon already running (pid $oldpid). Use './domo stop' first, or './domo logs'."
    fi
    warn "stale pid file (pid not alive); overwriting."
    rm -f "$PID_FILE"
  fi
  if [[ -n "$sig" ]] && pgrep -f -- "$sig" >/dev/null 2>&1; then
    die "a claude process matching this instance is already running (orphaned wrapper?). Run './domo stop' first."
  fi

  mkdir -p "$RUN_DIR"
  cd "$WORKSPACE" # cd BEFORE building argv so the workspace project-dir slug is correct
  build_claude_argv

  log "Starting BACKGROUND daemon in $WORKSPACE"
  log "Launch: ${CLAUDE_ARGV[*]}"
  log "Logfile: $LOG_FILE"

  {
    printf '\n===== domo start %s =====\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'channel=%s  permission=%s  argv=%s\n' "$DOMO_CHANNEL" "$PERMISSION_MODE" "${CLAUDE_ARGV[*]}"
  } >>"$LOG_FILE" 2>&1

  if [[ "${DOMO_NO_PTY:-0}" == "1" ]]; then
    # Plain detached background (verify-at-runtime: may exit on stdin EOF).
    # No PTY wrapper, so the recorded pid IS the claude process — stop can TERM it
    # directly and there is no orphaned child.
    nohup "${CLAUDE_ARGV[@]}" </dev/null >>"$LOG_FILE" 2>&1 &
  else
    # PTY-wrapped via macOS `script` so claude sees a controlling tty (no stdin EOF).
    # ⚠️ The recorded pid here is the `script` WRAPPER, not claude. On macOS the
    # PTY child (claude) runs in its OWN process group / session, so killing the
    # wrapper does NOT reap claude (verified: it orphans + survives). `stop` MUST
    # therefore tree-kill (see cmd_stop): it kills the wrapper AND pkills the exact
    # claude argv signature scoped to this repo. We persist that signature here.
    nohup script -q -F -e /dev/null "${CLAUDE_ARGV[@]}" </dev/null >>"$LOG_FILE" 2>&1 &
  fi
  # `disown` takes a JOB SPEC, not a PID, and bash 3.2 errors on a numeric arg.
  # `nohup` already detaches from SIGHUP, so disowning the current job (%%) is
  # belt-and-suspenders only and is allowed to no-op.
  disown %% 2>/dev/null || true
  local pid=$!
  printf '%s\n' "$pid" > "$PID_FILE"

  # Record the resolved claude argv signature so `stop` can reap the real claude
  # process even when `pid` is the `script` wrapper (PTY path). Scoped to THIS
  # repo via the workspace path + session flag so we never touch unrelated procs.
  write_daemon_sig

  # Brief liveness check so an immediate crash is reported now, not silently.
  sleep 1
  if kill -0 "$pid" 2>/dev/null; then
    log "Daemon started (pid $pid)."
    log "Tail logs with: ./domo logs    Stop with: ./domo stop"
  else
    rm -f "$PID_FILE" "$SIG_FILE"
    die "daemon exited immediately — see $LOG_FILE (last lines below):
$(tail -n 20 "$LOG_FILE" 2>/dev/null || true)"
  fi
}

# ---------------------------------------------------------------------------
# stop — kill the daemon by PID (TERM, wait, KILL) + sweep stray channel child.
# ---------------------------------------------------------------------------
cmd_stop() {
  local pid=""
  if [[ -f "$PID_FILE" ]]; then
    pid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
  fi

  if [[ -z "$pid" ]]; then
    log "not running (no pid file)."
  elif kill -0 "$pid" 2>/dev/null; then
    log "Stopping daemon (pid $pid)..."
    kill -TERM "$pid" 2>/dev/null || true
    local i=0
    while kill -0 "$pid" 2>/dev/null && [[ "$i" -lt 10 ]]; do sleep 0.5; i=$((i+1)); done
    if kill -0 "$pid" 2>/dev/null; then
      warn "did not exit on TERM; sending KILL."
      kill -KILL "$pid" 2>/dev/null || true
    fi
    log "Wrapper process stopped."
  else
    log "pid $pid not alive; cleaning up."
  fi

  # TREE-KILL the real claude process (#1): under the PTY path the recorded pid is
  # the `script` wrapper, whose child claude runs in a separate session and is
  # ORPHANED (not reaped) when the wrapper dies. We reap it by its recorded argv
  # signature, scoped to THIS instance. (Under DOMO_NO_PTY=1 the pid above already
  # IS claude, so this is a harmless no-op.)
  local sig=""
  if [[ -f "$SIG_FILE" ]]; then
    sig="$(tr -d '\n' < "$SIG_FILE" 2>/dev/null || true)"
  fi
  [[ -n "$sig" ]] || sig="$(daemon_kill_pattern)"
  if [[ -n "$sig" ]]; then
    # Match the claude argv (not the channel server.ts) by the scoped signature.
    if pgrep -f -- "$sig" >/dev/null 2>&1; then
      warn "Reaping claude process(es) matching scoped signature."
      pkill -TERM -f -- "$sig" 2>/dev/null || true
      local j=0
      while pgrep -f -- "$sig" >/dev/null 2>&1 && [[ "$j" -lt 10 ]]; do sleep 0.5; j=$((j+1)); done
      if pgrep -f -- "$sig" >/dev/null 2>&1; then
        warn "claude did not exit on TERM; sending KILL."
        pkill -KILL -f -- "$sig" 2>/dev/null || true
      fi
    fi
  fi

  rm -f "$PID_FILE" "$SIG_FILE"

  # Sweep stray channel children scoped to THIS repo path so we never touch
  # unrelated processes (the channel server is a separate child of claude).
  case "$DOMO_CHANNEL" in
    plow-chat)
      # The channel server is spawned as `bun run --cwd $PLOW_CHANNEL_DIR … start`,
      # so its argv contains the channel dir path — match on that (repo-scoped).
      if pgrep -f "$PLOW_CHANNEL_DIR" >/dev/null 2>&1; then
        warn "Sweeping stray plow-chat channel server(s)."
        pkill -f "$PLOW_CHANNEL_DIR" 2>/dev/null || true
      fi
      ;;
    fakechat)
      free_fakechat_port
      ;;
  esac
  log "Daemon stopped."
}

# ---------------------------------------------------------------------------
# status — resolved config + daemon liveness + channel state (no secrets).
# With --assert, exit non-zero if anything required is missing (mirrors doctor).
# ---------------------------------------------------------------------------
cmd_status() {
  local assert=0
  [[ "${1:-}" == "--assert" ]] && assert=1
  export_config_dir
  local ok=0

  local sid; sid="$(read_session_id)"
  log "CONFIG_DIR:      $CONFIG_DIR"
  log "WORKSPACE:       $WORKSPACE"
  log "DOMO_CHANNEL:    $DOMO_CHANNEL"
  log "session_id:      ${sid:-<none>}"
  log "permission mode: $PERMISSION_MODE"
  case "$DOMO_CHANNEL" in
    plow-chat) log "channel flag:    --dangerously-load-development-channels server:plow-chat"; log "channel dir:     $PLOW_CHANNEL_DIR" ;;
    fakechat)  log "channels flag:   $FAKECHAT_CHANNELS_FLAG"; log "fakechat port:   $FAKECHAT_PORT" ;;
  esac

  # Session jsonl present? (first-run vs resume.)
  if [[ -n "$sid" && -f "$PROJECTS_DIR/$sid.jsonl" ]]; then
    log "session jsonl:   present ($PROJECTS_DIR/$sid.jsonl) -> resume"
  else
    log "session jsonl:   missing -> first run (--session-id)"
  fi

  # Daemon liveness.
  if [[ -f "$PID_FILE" ]]; then
    local pid; pid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      log "daemon:          ALIVE (pid $pid)"
    else
      warn "daemon:          DEAD (stale pid file: ${pid:-empty})"; ok=1
    fi
  else
    log "daemon:          not running (no pid file)"
  fi

  # Channel state (never print the token).
  case "$DOMO_CHANNEL" in
    plow-chat)
      local tok chat
      tok="$(json_get "$PLOW_STATE_FILE" "token")"
      chat="$(json_get "$PLOW_STATE_FILE" "chat_uid")"
      if [[ -n "$tok" && -n "$chat" ]]; then
        log "plow-chat state: present (token present, chat_uid $chat)"
        # Permission sanity (belt-and-suspenders).
        local perm; perm="$(stat -f '%Lp' "$PLOW_STATE_FILE" 2>/dev/null || true)"
        [[ "$perm" == "600" ]] || warn "plow-chat state.json perms are $perm (expected 600)."
      else
        warn "plow-chat state: missing — run './domo activate'"; ok=1
      fi
      ;;
    fakechat)
      log "fakechat:        UI would bind http://localhost:$FAKECHAT_PORT"
      ;;
  esac

  if [[ "$assert" -eq 1 && "$ok" -ne 0 ]]; then
    die "status --assert: one or more required items missing (see WARNINGs)."
  fi
}

# ---------------------------------------------------------------------------
# logs — tail the daemon logfile.
# ---------------------------------------------------------------------------
cmd_logs() {
  local follow=1
  [[ "${1:-}" == "--no-follow" ]] && follow=0
  if [[ ! -f "$LOG_FILE" ]]; then
    log "no log yet; run './domo start'."
    return 0
  fi
  if [[ "$follow" -eq 1 ]]; then
    exec tail -f "$LOG_FILE"
  else
    exec tail -n 200 "$LOG_FILE"
  fi
}

# ---------------------------------------------------------------------------
# doctor — read-only preflight; non-zero exit on any failed assertion.
# ---------------------------------------------------------------------------
cmd_doctor() {
  export_config_dir
  local ok=0

  log "CONFIG_DIR:  $CONFIG_DIR"
  log "WORKSPACE:   $WORKSPACE"
  log "DOMO_CHANNEL: $DOMO_CHANNEL"

  if [[ -d "$WORKSPACE" ]]; then log "OK   workspace present"; else warn "MISS workspace absent (run './domo setup')"; ok=1; fi
  if command -v claude >/dev/null 2>&1; then log "OK   'claude' on PATH"; else warn "MISS 'claude' not on PATH"; ok=1; fi
  if command -v bun >/dev/null 2>&1; then log "OK   'bun' on PATH"; else warn "MISS 'bun' not on PATH (needed for plow-chat)"; [[ "$DOMO_CHANNEL" == "plow-chat" ]] && ok=1; fi

  # Auth: token OR stored login both work.
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]] || [[ -f "$ENV_FILE" ]] || [[ -f "$TOKEN_FILE" ]]; then
    log "OK   auth: token available (env or token file)"
  elif [[ -f "$CONFIG_DIR/.credentials.json" ]]; then
    log "OK   auth: interactive login present in $CONFIG_DIR"
  else
    log "INFO auth: no token/login detected — run './domo shell' then '/login' (creds may be in Keychain)."
  fi

  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    warn "WARN ANTHROPIC_API_KEY is set — must be UNSET for subscription auth."; ok=1
  else
    log "OK   ANTHROPIC_API_KEY is unset"
  fi

  # Session UUID.
  local sid; sid="$(read_session_id)"
  if [[ -n "$sid" ]]; then log "OK   session_id present ($sid)"; else warn "MISS session_id absent (run './domo setup')"; ok=1; fi

  log "permission mode: $PERMISSION_MODE"

  # Channel-specific.
  case "$DOMO_CHANNEL" in
    plow-chat)
      log "channel flag: --dangerously-load-development-channels server:plow-chat (MCP server registered via 'claude mcp add')"
      local missing=0
      for f in "$PLOW_CHANNEL_DIR/.claude-plugin/plugin.json" "$PLOW_CHANNEL_DIR/.mcp.json" "$PLOW_CHANNEL_DIR/server.ts"; do
        if [[ -f "$f" ]]; then log "OK   channel file: $(basename "$f")"; else warn "MISS channel file: $f"; missing=1; ok=1; fi
      done
      local tok; tok="$(json_get "$PLOW_STATE_FILE" "token")"
      if [[ -n "$tok" ]]; then
        local perm; perm="$(stat -f '%Lp' "$PLOW_STATE_FILE" 2>/dev/null || true)"
        if [[ "$perm" == "600" ]]; then log "OK   plow-chat state.json present (chmod 600, token present)"; else warn "WARN plow-chat state.json perms $perm (expected 600)"; ok=1; fi
      else
        warn "WARN plow-chat state.json has no token — run './domo activate'"
      fi
      ;;
    fakechat)
      log "channels flag: $FAKECHAT_CHANNELS_FLAG  (port $FAKECHAT_PORT)"
      ;;
  esac

  if [[ "$ok" -eq 0 ]]; then log "doctor: all checks passed."; else die "doctor: one or more checks failed (see WARNINGs)."; fi
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
usage() {
  cat >&2 <<EOF
Domo orchestrator

Usage: $(basename "$0") <command> [args]

Commands:
  setup            Idempotent bootstrap: isolated dirs + workspace + session UUID;
                   ensure the selected channel is loadable. Prints one-time steps.
  activate [--force]
                   (plow-chat) Plow handshake in curl: print the code to text, poll
                   redeem, write the chmod-600 state file. --force re-activates.
  shell            FOREGROUND interactive session (one-time consent / /login / debug).
  start            BACKGROUND detached daemon (PID file + logfile). Same pinned session.
  stop             Kill the daemon + sweep stray channel child.
  status [--assert] Resolved config + daemon liveness + channel state (no secrets).
  logs [--no-follow] Tail the daemon logfile.
  doctor           Read-only preflight; non-zero exit on any failed assertion.

Environment:
  DOMO_CHANNEL            plow-chat (default) | fakechat
  DOMO_HOME              base dir; default: this checkout
  DOMO_PERMISSION_MODE   permission mode; default 'auto'
  CLAUDE_CODE_OAUTH_TOKEN  optional headless subscription token
  FAKECHAT_PORT          fakechat UI port (default 8787); only for DOMO_CHANNEL=fakechat
  PLOW_CHAT_BASE_URL     Plow API base for activate (default https://api.plow.co)
  DOMO_NO_PTY=1          start without the 'script' PTY wrapper (plain background)
  DOMO_SESSION_FALLBACK=1  use latest-jsonl-by-mtime resume instead of pinned UUID
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    setup)    shift; cmd_setup "$@" ;;
    activate) shift; cmd_activate "$@" ;;
    shell)    shift; cmd_shell "$@" ;;
    start)    shift; cmd_start "$@" ;;
    stop)     shift; cmd_stop "$@" ;;
    status)   shift; cmd_status "$@" ;;
    logs)     shift; cmd_logs "$@" ;;
    doctor)   shift; cmd_doctor "$@" ;;
    ""|-h|--help|help) usage; [[ -z "$cmd" ]] && exit 1 || exit 0 ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

main "$@"

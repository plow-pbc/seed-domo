# Accidental checkout-scoped Domo runtime state. DOMO_HOME is $HOME/.domo; the
# repo root must not be used as a runtime home. NEVER track any of this.
/.claude/

# Dedicated, scoped agent workspace (`start` runs from here).
/workspace/
/calendar-check-workspace/

# Local design notes / specs — working history, not part of the published SEED.
/docs/

# Local subscription token / env, if the operator persists them in the checkout.
/.env

# Belt-and-suspenders: explicitly ignore Domo daemon metadata, the Plow Chat secret
# state (chmod-600 user-wide Bearer token + transient activation secret), and the
# daemon run dir (pid/log). These all live under /.claude/ (ignored above) but are
# listed by path too so a secret can never slip into git even if /.claude/ rules change.
/.claude/domo.json
/.claude/plow-chat/
/.claude/plow-chat/state.json
/.claude/plow-chat/activation.json
/.claude/plow-chat/last_seen.json
/.claude/run/
/.claude/run/domo.log
/.claude/run/domo.pid

# SEED install report — seed-install writes this at the repo root on each run;
# the seed-install contract recommends authors gitignore it so reruns don't churn.
/install-report.json

# Domo install state contains household interview answers and later install secrets.
/install-state.json

.DS_Store

# Stray output of the `script` PTY recorder (start uses /dev/null, but belt-and-suspenders)
typescript

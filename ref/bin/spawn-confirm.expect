#!/usr/bin/env expect -f
#
# spawn-confirm.expect — launch a command under a PTY, answer Claude Code's
# once-per-launch `--dangerously-load-development-channels` confirmation TUI
# (option 1, "I am using this for local development", is pre-selected → send Enter),
# then keep the session alive forever as the persistent channel listener.
#
# Why: custom channels aren't on the research-preview allowlist, so they load via
# the development flag, which prompts EVERY launch. A backgrounded daemon has no
# terminal to answer it; this driver does. `-p` mode skips the prompt but exits
# (one-shot), so it can't be the daemon — hence this PTY driver.
#
# Usage:  expect spawn-confirm.expect <command> [args...]
# The whole argv (after this script) is the command to spawn.
#
# The confirmation menus render some prompt words with cursor-positioning escapes,
# so the prompt text is not always contiguous in the byte stream. Stable option
# labels are better anchors: dev-channel confirmation defaults safely to option 1,
# but the fullscreen renderer prompt defaults to "Yes", so select option 2
# explicitly when that prompt is detected.

set timeout 90

# Spawn the real command with a PTY so Claude runs interactive (and thus shows the
# prompt we can answer). -noecho keeps our own argv out of the log.
eval spawn -noecho $argv

# A genuinely fresh config dir shows first-run onboarding (the theme picker, the
# fullscreen-renderer upsell, and possibly a trust prompt) around the dev-channels
# confirmation. Dismiss setup prompts with safe defaults, but choose "Not now" for
# fullscreen so daemon launches do not switch renderers or wedge on the upsell.
# NOTE: we cannot cross a /login wall here (there are no credentials to type) — if
# claude parks at login, `domo start`'s readiness probe surfaces it to the user.
set tries 0
while {$tries < 8} {
  incr tries
  expect {
    "Yes, try it" { send "2\r"; exp_continue }
    -re "text style|Choose the text|Let.s get started|trust the files|trust this folder|project.*trust|Yes, I trust" { send "\r"; exp_continue }
    "cancel"  { send "\r"; break }
    eof       { exit 0 }
    timeout   { send "\r"; break }
  }
}

set timeout 8
set tries 0
while {$tries < 4} {
  incr tries
  expect {
    "Yes, try it" { send "2\r"; exp_continue }
    -re "text style|Choose the text|Let.s get started|trust the files|trust this folder|project.*trust|Yes, I trust" { send "\r"; exp_continue }
    "cancel"  { send "\r"; exp_continue }
    eof       { exit 0 }
    timeout   { break }
  }
}

# Steady state: keep the persistent session running until claude exits on its own.
set timeout -1
expect eof

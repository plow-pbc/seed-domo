#!/usr/bin/env bash
#
# domo — Domo orchestrator CLI
#
# Domo is a channels-only, host-raw, subscription-billed household assistant. It runs
# as ONE persistent `claude --channels` session in Claude Code "auto mode". This CLI
# bootstraps that session, runs the Plow Chat activation handshake, and runs the
# session either in the FOREGROUND (`shell`, interactive — for one-time consent/login)
# or as a detached BACKGROUND daemon (`start`/`stop`/`status`/`logs`). shell and start
# share ONE pinned session UUID so they are a single continuous conversation.
#
# Authoritative design: ../../SEED.md (this repo's SEED) and the build contract that produced it.
#
# Permission posture: `--permission-mode auto` (classifier-gated). No custom PreToolUse
# allowlist (that was intentionally removed — do NOT reintroduce it). bypassPermissions
# is reachable via DOMO_PERMISSION_MODE but is NOT the default.
#
# Channel selector: DOMO_CHANNEL=plow-chat (default). plow-chat reads its Bearer
# token from a chmod-600 state file (path via PLOW_CHAT_STATE).
#
# Subcommands:
#   setup     idempotent bootstrap (dirs + workspace + session UUID + channel loadable)
#   activate  Plow handshake in bash+curl -> chmod-600 state file (plow-chat only)
#   shell     run the session in the FOREGROUND (interactive; one-time consent/login)
#   start     run the SAME session in the BACKGROUND, detached (PID file + logfile)
#   stop      kill the daemon by PID file + sweep stray channel child
#   status    resolved config + daemon liveness + channel state (no secrets)
#   logs      tail the daemon logfile
#   doctor    read-only preflight
#   reset     full teardown: stop daemon, delete Plow chat, logout auth, rm DOMO_HOME
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Source-of-truth paths
# ---------------------------------------------------------------------------

# REPO_ROOT is resolved from this script's own location so the build is portable.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# DOMO_HOME is the isolated Claude home for this instance. It defaults to a
# dedicated persistent home outside the checkout so repo installs never write
# runtime state into the source tree.
DOMO_HOME="${DOMO_HOME:-$HOME/.domo}"
CONFIG_DIR="$DOMO_HOME/.claude"
WORKSPACE="$DOMO_HOME/workspace"

# Daemon runtime (gitignored).
RUN_DIR="$CONFIG_DIR/run"
LOG_FILE="$RUN_DIR/domo.log"
PID_FILE="$RUN_DIR/domo.pid"
# Records the launched claude argv signature so `stop` can tree-kill the real
# claude process when the PID file points at the `script` PTY wrapper (see #1).
SIG_FILE="$RUN_DIR/domo.sig"

# Domo metadata (gitignored): holds the pinned session UUID.
META_FILE="$CONFIG_DIR/domo.json"
INSTALL_STATE_FILE="$DOMO_HOME/install-state.json"

# Optional gitignored token/env, sourced if present (headless subscription auth).
ENV_FILE="$DOMO_HOME/.env"
TOKEN_FILE="$CONFIG_DIR/oauth-token"

# Channel selection. Default plow-chat (the real surface).
DOMO_CHANNEL="${DOMO_CHANNEL:-plow-chat}"

# --- plow-chat paths ---
PLOW_DIR="$CONFIG_DIR/plow-chat"                 # chmod-700 dir holding secrets
PLOW_STATE_FILE="$PLOW_DIR/state.json"           # redeemed {base_url,token,chat_uid}
PLOW_ACTIVATION_FILE="$PLOW_DIR/activation.json" # transient pre-token secret
PLOW_CHANNEL_DIR="$SCRIPT_DIR/channels/plow-chat" # channel server dir (registered as an MCP server)
PLOW_BASE_URL="${PLOW_CHAT_BASE_URL:-https://api.plow.co}"
SPAWN_CONFIRM="$SCRIPT_DIR/bin/spawn-confirm.expect" # drives the dev-channels confirmation for `start`
ACTIVATE_PIECE="$SCRIPT_DIR/domo-activate-piece.sh"
LOGIN_PIECE="$SCRIPT_DIR/domo-login-piece.sh"
READY_PIECE="$SCRIPT_DIR/domo-ready-piece.sh"
DOMO_INSTALL_TEST_MODE="${DOMO_INSTALL_TEST_MODE:-0}"
ACTIVATION_TIMEOUT_SECONDS=300
ACTIVATION_POLL_INTERVAL_SECONDS=3
ACTIVATION_MAX_RESENDS=0
WS_TIMEOUT_MS=300000

# Permission posture for the persistent session (carried from run.sh).
PERMISSION_MODE="${DOMO_PERMISSION_MODE:-auto}"

# Workspace project-dir slug: claude slugs the CWD by replacing every '/' and '.'
# with '-'. start/shell cd into $WORKSPACE before exec, so the project dir is the
# WORKSPACE slug (verified layout in $CONFIG_DIR/projects).
WORKSPACE_SLUG="$(printf '%s' "$WORKSPACE" | sed 's/[\/.]/-/g')"
PROJECTS_DIR="$CONFIG_DIR/projects/$WORKSPACE_SLUG"

# ---------------------------------------------------------------------------
# Small helpers
# ---------------------------------------------------------------------------
log()  { printf '[domo] %s\n' "$*" >&2; }
warn() { printf '[domo] WARNING: %s\n' "$*" >&2; }
die()  { printf '[domo] ERROR: %s\n' "$*" >&2; exit 1; }

int_at_least() {
  local raw="$1" default="$2" floor="$3"
  [[ "$raw" =~ ^[0-9]+$ ]] || { printf '%s' "$default"; return 0; }
  if [[ "$raw" -lt "$floor" ]]; then printf '%s' "$floor"; else printf '%s' "$raw"; fi
}

int_or_default() {
  local raw="$1" default="$2"
  [[ "$raw" =~ ^[0-9]+$ ]] && printf '%s' "$raw" || printf '%s' "$default"
}

apply_env_policy() {
  if [[ "$DOMO_INSTALL_TEST_MODE" == "1" ]]; then
    ACTIVATION_TIMEOUT_SECONDS="$(int_at_least "${DOMO_ACTIVATION_TIMEOUT_SECONDS:-300}" 300 5)"
    ACTIVATION_POLL_INTERVAL_SECONDS="$(int_at_least "${DOMO_ACTIVATION_POLL_INTERVAL_SECONDS:-3}" 3 1)"
    ACTIVATION_MAX_RESENDS="$(int_or_default "${DOMO_ACTIVATION_MAX_RESENDS:-0}" 0)"
    WS_TIMEOUT_MS="$(int_at_least "${DOMO_WS_TIMEOUT_MS:-300000}" 300000 1000)"
  fi
}

# strip_ansi — filter stdin->stdout, removing the ANSI/control noise the claude
# TUI writes into domo.log (CSI/OSC/DCS escapes, charset designators, carriage
# returns, stray control bytes). Dumping that raw can flip the terminal into a
# mode where Ctrl+C stops working; stripping it keeps the terminal sane. Keeps
# TAB (\t) and NL (\n). Falls back to a passthrough `cat` if perl is missing.
strip_ansi() {
  if command -v perl >/dev/null 2>&1; then
    perl -pe 'BEGIN{$|=1}
      s/\e\[[0-9;?]*[ -\/]*[@-~]//g;       # CSI: colors, cursor moves, ?modes
      s/\e\][^\a\e]*(?:\a|\e\\)//g;          # OSC: title/hyperlink, BEL/ST term
      s/\e[PX^_].*?(?:\a|\e\\)//g;           # DCS/SOS/PM/APC strings
      s/\e[ -\/]*[0-~]//g;                   # charset designators + short escapes
      s/[\r\x00-\x08\x0b\x0c\x0e-\x1f]//g;   # stray CR + control bytes (keep \t \n)
    '
  else
    cat
  fi
}

# Export the isolated config dir — scopes plugins/connectors/sessions/auth/channel
# state to the Domo instance. MUST be exported in every subcommand that launches claude.
export_config_dir() {
  export CLAUDE_CONFIG_DIR="$CONFIG_DIR"
  log "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR"
}

# _dash <verb> [args…] — push to the install dashboard IF one is running. Best
# effort and NEVER fatal: if the installer client or a live server-info isn't
# present it silently no-ops, so the mechanics work identically with or without
# the dashboard. This is how the rich, user-actionable status (e.g. the Plow
# verification panel) appears on the page automatically when the agent runs the
# normal commands, instead of relying on the agent to remember to push it.
_dash() {
  [[ "${DOMO_DASHBOARD_MIRROR_STATE:-0}" == "1" ]] && return 0
  local client="$SCRIPT_DIR/installer/client.sh"
  [[ -f "$client" ]] || return 0
  local sdir="${INSTALLER_STATE_DIR:-${DOMO_INSTALLER_STATE_DIR:-${TMPDIR:-/tmp}/installer-ui}}"
  [[ -f "$sdir/server-info" ]] || return 0
  bash "$client" "$@" >/dev/null 2>&1 || true
}

require_claude() {
  command -v claude >/dev/null 2>&1 || die "the 'claude' CLI is not on PATH. Install Claude Code first."
}

require_bun() {
  command -v bun >/dev/null 2>&1 || die "the 'bun' runtime is not on PATH (needed for the plow-chat channel)."
}

require_curl() {
  command -v curl >/dev/null 2>&1 || die "'curl' is not on PATH (needed for ./domo activate)."
}

# Resolve subscription auth. The token is OPTIONAL:
#   1. CLAUDE_CODE_OAUTH_TOKEN (env, then $ENV_FILE, then $TOKEN_FILE) — headless path.
#   2. Otherwise the interactive login stored in the isolated config dir (/login).
# NON-FATAL: never blocks start/shell. Always unsets ANTHROPIC_API_KEY (subscription).
ensure_auth() {
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" && -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    set +u; source "$ENV_FILE"; set -u
  fi
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" && -f "$TOKEN_FILE" ]]; then
    CLAUDE_CODE_OAUTH_TOKEN="$(tr -d '[:space:]' < "$TOKEN_FILE")"
  fi
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
    export CLAUDE_CODE_OAUTH_TOKEN
    log "Auth: using CLAUDE_CODE_OAUTH_TOKEN (headless subscription token)."
  else
    log "Auth: no token set — using the interactive login in $CONFIG_DIR."
    log "      If this instance isn't logged in yet, run './domo shell' and '/login' once."
  fi
  # Keep subscription auth; never silently fall back to metered API billing.
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    warn "ANTHROPIC_API_KEY is set; unsetting it so subscription auth is used."
    unset ANTHROPIC_API_KEY
  fi
}

# Read a top-level string field from a small JSON file using bun (already a hard dep
# of the channel). Echoes the value (empty if missing/unparseable). NEVER used for
# the token in any path that prints.
json_get() { # json_get <file> <field>
  local file="$1" field="$2"
  [[ -f "$file" ]] || { printf ''; return 0; }
  bun -e '
    // NOTE: under `bun -e`, process.argv = [bunPath, ...userArgs] (no script slot),
    // so user args start at index 1. Slice(1) normalizes to a 0-based list.
    const A = process.argv.slice(1);
    const [file, field] = [A[0], A[1]];
    try {
      const o = JSON.parse(require("fs").readFileSync(file, "utf8"));
      const v = o?.[field];
      process.stdout.write(v == null ? "" : String(v));
    } catch { process.stdout.write(""); }
  ' "$file" "$field" 2>/dev/null || printf ''
}

# ---------------------------------------------------------------------------
# Session pinning — one UUID shared by shell and start (ONE continuous session).
# ---------------------------------------------------------------------------

# Read the pinned session UUID from domo.json (empty if none yet).
read_session_id() { json_get "$META_FILE" "session_id"; }

# Write/refresh domo.json with the given session_id (atomic; umask 077).
# Preserves any EXISTING `created` and `channel` so a fallback re-persist (or a
# run under a different DOMO_CHANNEL) does not silently rewrite the pinned
# session's original metadata; only fills them in when absent (#12).
write_meta() { # write_meta <session_id>
  local sid="$1" iso
  iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mkdir -p "$CONFIG_DIR"
  local tmp; tmp="$(umask 077; mktemp "$CONFIG_DIR/.domo.json.XXXXXX")"
  META_FILE="$META_FILE" DOMO_CHANNEL="$DOMO_CHANNEL" bun -e '
    // `bun -e` argv has no script slot; user args start at index 1.
    const [out, sid, iso] = process.argv.slice(1);
    const fs = require("fs");
    let prev = {};
    try { prev = JSON.parse(fs.readFileSync(process.env.META_FILE, "utf8")); } catch {}
    fs.writeFileSync(out, JSON.stringify({
      session_id: sid,
      // created/channel are advisory; keep the originals if present.
      channel: prev.channel ?? process.env.DOMO_CHANNEL,
      created: prev.created ?? iso,
    }, null, 2) + "\n");
  ' "$tmp" "$sid" "$iso"
  chmod 600 "$tmp"
  mv -f "$tmp" "$META_FILE"
}

# Resolve the launch session flag pair into the global array SESSION_FLAG[].
#
# FIRST-RUN DETECTION: a session already exists iff its jsonl is on disk under the
# WORKSPACE project dir. If absent -> first run -> --session-id <uuid>. If present ->
# resume -> --resume <uuid>. Both shell and start call this so they agree.
#
# ⚠️ COMPOSE-VERIFICATION (runtime-unverifiable here): --session-id/--resume are each
# confirmed present in `claude --help` but their composition with --channels is not
# verified in this build. If they DON'T compose, the documented fallback is:
# launch WITHOUT --session-id on first run, then on later starts resume the LATEST
# jsonl by mtime under the workspace project dir and persist that id back to domo.json.
# Set DOMO_SESSION_FALLBACK=1 to take that path.
SESSION_FLAG=()
resolve_session_flag() {
  local sid; sid="$(read_session_id)"
  [[ -n "$sid" ]] || die "no session_id in $META_FILE — run './domo setup' first."

  local session_file="$PROJECTS_DIR/$sid.jsonl"

  if [[ "${DOMO_SESSION_FALLBACK:-0}" == "1" ]]; then
    # Escape-hatch path: don't pin a UUID; resume the latest jsonl by mtime.
    local latest
    latest="$(ls -t "$PROJECTS_DIR"/*.jsonl 2>/dev/null | head -1 || true)"
    if [[ -n "$latest" ]]; then
      local found; found="$(basename "$latest" .jsonl)"
      write_meta "$found" # persist discovered id so future runs are deterministic
      SESSION_FLAG=(--resume "$found")
      log "Session (fallback): --resume $found (latest jsonl by mtime)."
    else
      SESSION_FLAG=() # let claude create a fresh jsonl on first run
      log "Session (fallback): no jsonl yet; launching without a session flag (claude creates one)."
    fi
    return 0
  fi

  if [[ -f "$session_file" ]]; then
    SESSION_FLAG=(--resume "$sid")
    log "Session: --resume $sid (existing jsonl found)."
  else
    SESSION_FLAG=(--session-id "$sid")
    log "Session: --session-id $sid (first run; no jsonl yet)."
  fi
}

# ---------------------------------------------------------------------------
# Channel argv assembly — builds the global arrays CHANNEL_ARGS[] (claude flags)
# and sets per-channel env. Mirrors run.sh's CHANNELS_FLAG handling, generalized.
# ---------------------------------------------------------------------------
CHANNEL_ARGS=()
CHANNELS_FLAG=""
PLUGIN_DIR=""
prepare_channel_env() {
  case "$DOMO_CHANNEL" in
    plow-chat)
      # plow-chat is a CUSTOM channel (not on the research-preview allowlist), so it
      # loads via --dangerously-load-development-channels server:<name>, NOT --channels
      # / --plugin-dir. The MCP server named 'plow-chat' is registered by `domo setup`
      # (claude mcp add), so the `server:` form resolves. (cite channels-reference.md.)
      CHANNELS_FLAG="server:plow-chat"
      # The server reads its secrets from this absolute path.
      export PLOW_CHAT_STATE="$PLOW_STATE_FILE"
      CHANNEL_ARGS=(--dangerously-load-development-channels "$CHANNELS_FLAG")
      log "Channel: plow-chat (dev channel server:plow-chat); PLOW_CHAT_STATE=$PLOW_CHAT_STATE"
      [[ -f "$PLOW_STATE_FILE" ]] || warn "plow-chat state.json missing — run './domo activate' (the channel loads but reply errors until then)."
      ;;
    *)
      die "unknown DOMO_CHANNEL='$DOMO_CHANNEL' (expected plow-chat)."
      ;;
  esac
}

# Build the full claude argv into the global array CLAUDE_ARGV[]. shell and start
# call this so they launch the IDENTICAL command (one continuous pinned session).
CLAUDE_ARGV=()
build_claude_argv() {
  prepare_channel_env
  resolve_session_flag
  CLAUDE_ARGV=(claude "${CHANNEL_ARGS[@]}" --permission-mode "$PERMISSION_MODE")
  if [[ ${#SESSION_FLAG[@]} -gt 0 ]]; then
    CLAUDE_ARGV+=("${SESSION_FLAG[@]}")
  fi
}

# ---------------------------------------------------------------------------
# setup — idempotent bootstrap
# ---------------------------------------------------------------------------
cmd_setup() {
  export_config_dir
  require_claude

  log "Creating isolated dirs..."
  mkdir -p "$CONFIG_DIR" "$WORKSPACE" "$RUN_DIR"
  mkdir -p "$PLOW_DIR"; chmod 700 "$PLOW_DIR"

  # Generate + persist the pinned session UUID if domo.json has none.
  local sid; sid="$(read_session_id)"
  if [[ -z "$sid" ]]; then
    command -v uuidgen >/dev/null 2>&1 || die "uuidgen not found (needed to mint the session UUID)."
    sid="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    write_meta "$sid"
    log "Generated session UUID: $sid (stored in $META_FILE)."
  else
    log "Session UUID already present: $sid."
  fi

  # Ensure the selected channel is loadable.
  case "$DOMO_CHANNEL" in
    plow-chat)
      require_bun
      local missing=0
      for f in "$PLOW_CHANNEL_DIR/.claude-plugin/plugin.json" "$PLOW_CHANNEL_DIR/.mcp.json" "$PLOW_CHANNEL_DIR/server.ts"; do
        if [[ -f "$f" ]]; then log "OK   channel file present: $f"; else warn "MISS channel file absent: $f"; missing=1; fi
      done
      [[ "$missing" -eq 0 ]] || die "plow-chat channel dir incomplete at $PLOW_CHANNEL_DIR."
      # Register plow-chat as a manually-configured MCP server so `server:plow-chat`
      # resolves for --dangerously-load-development-channels (NOT --plugin-dir). The
      # spawned server inherits PLOW_CHAT_STATE from the env domo exports at launch.
      # Use the absolute channel dir (no ${CLAUDE_PLUGIN_ROOT}, which is plugin-only).
      log "Registering MCP server 'plow-chat' (user scope) -> bun start in $PLOW_CHANNEL_DIR ..."
      claude mcp remove plow-chat </dev/null >/dev/null 2>&1 || true   # idempotent: drop any stale registration
      if claude mcp add plow-chat --scope user -- \
           bun run --cwd "$PLOW_CHANNEL_DIR" --shell=bun --silent start </dev/null; then
        log "OK   plow-chat MCP server registered."
      else
        warn "claude mcp add plow-chat returned non-zero — check 'claude mcp list'."
      fi
      log "plow-chat loads via --dangerously-load-development-channels server:plow-chat."
      ;;
    *) die "unknown DOMO_CHANNEL='$DOMO_CHANNEL'." ;;
  esac

  log "Setup complete (channel=$DOMO_CHANNEL)."
}

# ---------------------------------------------------------------------------
# activate — Plow handshake (bash + curl only; plow-chat). Writes chmod-600 state.
# ---------------------------------------------------------------------------
activation_mode() {
  [[ -f "$INSTALL_STATE_FILE" ]] || { printf 'solo'; return 0; }
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    try {
      const o = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
      process.stdout.write(String(o?.interview?.mode || "solo"));
    } catch {
      process.stdout.write("solo");
    }
  '
}

json_value() {
  local path="$1"
  bun -e '
    const fs = require("fs");
    const path = process.argv.slice(1)[0].split(".");
    let v;
    try {
      v = JSON.parse(fs.readFileSync(0, "utf8"));
    } catch (err) {
      console.error(`invalid JSON while reading ${process.argv.slice(1)[0]}: ${err.message}`);
      process.exit(2);
    }
    for (const part of path) v = v == null ? undefined : v[part];
    process.stdout.write(v == null ? "" : String(v));
  ' "$path"
}

plow_http_json() {
  local method="$1" path="$2" body="${3:-}" token="${4:-}"
  local url="${PLOW_BASE_URL%/}$path" out err config code rc
  out="$(mktemp "${TMPDIR:-/tmp}/domo-plow-body.XXXXXX")"
  err="$(mktemp "${TMPDIR:-/tmp}/domo-plow-err.XXXXXX")"
  plow_http_cleanup() {
    rm -f "$out" "$err" "${config:-}"
  }
  trap 'plow_http_cleanup' EXIT
  trap 'plow_http_cleanup; exit 130' INT
  trap 'plow_http_cleanup; exit 143' TERM
  trap 'plow_http_cleanup; exit 129' HUP
  local args=(-sS -o "$out" -w "%{http_code}" -X "$method" "$url" -H 'Content-Type: application/json')
  if [[ -n "$token" ]]; then
    config="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-plow-curl.XXXXXX")"
    TOKEN="$token" bun -e '
      const fs = require("fs");
      const out = process.argv.slice(1)[0];
      const token = process.env.TOKEN.replace(/\\/g, "\\\\").replace(/"/g, "\\\"");
      fs.writeFileSync(out, `header = "Authorization: Bearer ${token}"\n`);
    ' "$config"
    args+=(--config "$config")
  fi
  if [[ "$method" != "GET" ]]; then
    # Body via stdin keeps activation payloads out of argv; bearer tokens use
    # curl --config above for the same ps-safe reason.
    args+=(--data-binary @-)
    set +e
    code="$(printf '%s' "$body" | curl "${args[@]}" 2>"$err")"
    rc=$?
    set -e
  else
    set +e
    code="$(curl "${args[@]}" 2>"$err")"
    rc=$?
    set -e
  fi
  if [[ "$rc" -ne 0 ]]; then
    local msg; msg="$(tr '\n' ' ' < "$err" | sed 's/[[:space:]]\+/ /g')"
    plow_http_cleanup
    die "Plow API $method $path failed: ${msg:-curl exit $rc}"
  fi
  if [[ ! "$code" =~ ^[0-9][0-9][0-9]$ || "$code" -lt 200 || "$code" -ge 300 ]]; then
    local response; response="$(tr '\n' ' ' < "$out" | sed 's/[[:space:]]\+/ /g')"
    plow_http_cleanup
    die "Plow API $method $path returned HTTP ${code:-000}: ${response:-<empty response>}"
  fi
  if ! bun -e 'JSON.parse(require("fs").readFileSync(process.argv.slice(1)[0], "utf8"))' "$out" 2>"$err"; then
    local parse_err; parse_err="$(tr '\n' ' ' < "$err" | sed 's/[[:space:]]\+/ /g')"
    local response; response="$(tr '\n' ' ' < "$out" | sed 's/[[:space:]]\+/ /g')"
    plow_http_cleanup
    die "Plow API $method $path returned invalid JSON: ${parse_err:-parse failed}; body=${response:-<empty>}"
  fi
  cat "$out"
  plow_http_cleanup
  trap - EXIT INT TERM HUP
}

plow_auth_activate() {
  local payload="$1"
  plow_http_json POST /v1/auth/activate "$payload"
}

write_activation_state_file() {
  local response="$1"
  local tmp; tmp="$(umask 077; mktemp "$PLOW_DIR/.activation.json.XXXXXX")"
  printf '%s' "$response" | bun -e '
    const fs = require("fs");
    const s = fs.readFileSync(0, "utf8");
    const a = JSON.parse(s);
    const A = process.argv.slice(1);
    const out = A[0];
    fs.writeFileSync(out, JSON.stringify({
      base_url: A[1].replace(/\/$/, ""),
      activation_secret: a.activation_secret,
      display_code: a.display_code,
      send_to: a.send_to,
      line_uid: a.line_id ?? a.line_uid ?? null,
    }, null, 2) + "\n");
  ' "$tmp" "$PLOW_BASE_URL"
  chmod 600 "$tmp"; mv -f "$tmp" "$PLOW_ACTIVATION_FILE"
}

persist_solo_activation_detail() {
  local response="$1"
  local response_file tmp
  response_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-solo-activation.XXXXXX")"
  printf '%s' "$response" > "$response_file"
  tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" BASE_URL="$PLOW_BASE_URL" bun -e '
    const fs = require("fs");
    const [out, responseFile] = process.argv.slice(1);
    let state = {};
    if (fs.existsSync(process.env.INSTALL_STATE_FILE)) {
      state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    }
    const a = JSON.parse(fs.readFileSync(responseFile, "utf8"));
    state.interview = state.interview && typeof state.interview === "object"
      ? { ...state.interview, status: state.interview.status ?? (state.interview.mode ? "collected" : "pending"), members: state.interview.members ?? [] }
      : { status: "pending", members: [] };
    state.activation = state.activation || "pending";
    state.login = state.login || "pending";
    state.calendar = state.calendar || "pending";
    state.build = state.build || "pending";
    state.ready = state.ready || false;
    state.activation_detail = {
      mode: "solo",
      base_url: process.env.BASE_URL.replace(/\/$/, ""),
      status: "pending",
      activation_secret: a.activation_secret,
      display_code: a.display_code,
      send_to: a.send_to,
      line_uid: a.line_id ?? a.line_uid ?? null,
    };
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp" "$response_file"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
  rm -f "$response_file"
}

persist_group_owner_activation_detail() {
  local response="$1" status="${2:-pending}"
  local response_file tmp
  response_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-group-owner.XXXXXX")"
  printf '%s' "$response" > "$response_file"
  tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" BASE_URL="$PLOW_BASE_URL" STATUS="$status" bun -e '
    const fs = require("fs");
    const [out, responseFile] = process.argv.slice(1);
    let state = {};
    if (fs.existsSync(process.env.INSTALL_STATE_FILE)) {
      state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    }
    const owner = JSON.parse(fs.readFileSync(responseFile, "utf8"));
    state.interview = state.interview && typeof state.interview === "object"
      ? { ...state.interview, status: state.interview.status ?? (state.interview.mode ? "collected" : "pending"), members: state.interview.members ?? [] }
      : { status: "pending", members: [] };
    state.activation = state.activation || "pending";
    state.login = state.login || "pending";
    state.calendar = state.calendar || "pending";
    state.build = state.build || "pending";
    state.ready = state.ready || false;
    state.activation_detail = {
      ...(state.activation_detail || {}),

push_activation_dashboard_row() {
  local name="$1" status="$2" display_code="${3:-}" send_to="${4:-}" is_self="${5:-false}" row_id="${6:-}"
  _dash installer_step plow active "Activate Plow chat — text the code"
  if [[ "$is_self" == "true" || "$is_self" == "self" ]]; then
    _dash installer_verify "$name" "$status" "$display_code" "$send_to" self "$row_id"
  else
    _dash installer_verify "$name" "$status" "$display_code" "$send_to" false "$row_id"
  fi
}

mark_activation_dashboard_verified() {
  local name="${1:-You}" row_id="${2:-}" step_done="${3:-false}"
  _dash installer_verify "$name" verified "" "" false "$row_id"
  [[ "$step_done" == "true" ]] && _dash installer_step plow ok "Plow chat active"
}

poll_activation_redeem() {
  local activation_secret="$1"
  local deadline=$(( $(date +%s) + ACTIVATION_TIMEOUT_SECONDS ))
  local status="pending" redeem payload
  while :; do
    payload="$(ACTIVATION_SECRET="$activation_secret" bun -e 'process.stdout.write(JSON.stringify({activation_secret: process.env.ACTIVATION_SECRET}))')"
    redeem="$(plow_http_json POST /v1/auth/activate/redeem "$payload")" || return 1
    status="$(printf '%s' "$redeem" | json_value status)"
    if [[ "$status" == "verified" ]]; then
      printf '%s' "$redeem"
      return 0
    fi
    [[ "$status" == "pending" ]] || die "activation redeem returned unexpected status '$status'."
    if [[ "$(date +%s)" -ge "$deadline" ]]; then
      return 75
    fi
    sleep "$ACTIVATION_POLL_INTERVAL_SECONDS"
  done
}

write_plow_channel_state_file() {
  local token="$1" chat_uid="$2"
  local stmp; stmp="$(umask 077; mktemp "$PLOW_DIR/.state.json.XXXXXX")"
  TOKEN="$token" CHAT_UID="$chat_uid" BASE_URL="$PLOW_BASE_URL" bun -e '
    const fs = require("fs");
    const out = process.argv.slice(1)[0];
    fs.writeFileSync(out, JSON.stringify({
      base_url: process.env.BASE_URL.replace(/\/$/, ""),
      token: process.env.TOKEN,
      chat_uid: process.env.CHAT_UID,
    }, null, 2) + "\n");
  ' "$stmp"
  chmod 600 "$stmp"; mv -f "$stmp" "$PLOW_STATE_FILE"
}

set_install_activation_status() {
  local status="$1"
  mkdir -p "$DOMO_HOME"
  local tmp; tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" STATUS="$status" bun -e '
    const fs = require("fs");
    const out = process.argv.slice(1)[0];
    let prev = {};
    if (fs.existsSync(process.env.INSTALL_STATE_FILE)) {
      prev = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    }
    prev.interview = prev.interview && typeof prev.interview === "object"
      ? { ...prev.interview, status: prev.interview.status ?? (prev.interview.mode ? "collected" : "pending"), members: prev.interview.members ?? [] }
      : { status: "pending", members: [] };
    prev.activation = process.env.STATUS;
    prev.login = prev.login || "pending";
    prev.calendar = prev.calendar || "pending";
    prev.build = prev.build || "pending";
    prev.ready = prev.ready || false;
    if (prev.activation_detail?.mode === "solo" && process.env.STATUS === "complete") {
      prev.activation_detail.status = "verified";
    }
    fs.writeFileSync(out, JSON.stringify(prev, null, 2) + "\n");
  ' "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
}

complete_activation() {
  local chat_uid="$1" mode="${2:-solo}"
  rm -f "$PLOW_ACTIVATION_FILE"
  set_install_activation_status complete
  [[ "$mode" == "solo" ]] && mark_activation_dashboard_verified "You" "" true
  [[ "$mode" == "group" ]] && _dash installer_step plow ok "Plow chat active"
  log "Activation verified. State written to $PLOW_STATE_FILE (chmod 600). chat_uid=$chat_uid"
  log "Token stored (NOT printed). If a session is already running: './domo stop && ./domo start' to pick it up."
}

activate_solo_path() {
  local resend_count=0
  while :; do
    log "Requesting Plow activation at $PLOW_BASE_URL ..."
    local response activation_secret display_code send_to line_id
    response="$(plow_auth_activate '{"name":"Domo","provision_chat":true}')" \
      || die "activation request failed (POST /v1/auth/activate). Check connectivity."

    activation_secret="$(printf '%s' "$response" | json_value activation_secret)"
    display_code="$(printf '%s' "$response" | json_value display_code)"
    send_to="$(printf '%s' "$response" | json_value send_to)"
    line_id="$(printf '%s' "$response" | bun -e 'const o=JSON.parse(require("fs").readFileSync(0,"utf8"));process.stdout.write(String(o.line_id??o.line_uid??""))')"

    [[ -n "$activation_secret" ]] || die "activation response missing activation_secret."
    [[ -n "$display_code" && -n "$send_to" ]] || die "activation response missing display_code/send_to."

    write_activation_state_file "$response"
    persist_solo_activation_detail "$response"

    cat >&2 <<EOF

[domo] ============================================================
[domo] PLOW ACTIVATION — ACTION REQUIRED
[domo] ============================================================
[domo] From the phone you want bound to this chat, text EXACTLY:
[domo]
[domo]     $display_code
[domo]
[domo]   to:  $send_to
[domo]
[domo] (line: ${line_id:-unknown})  Polling for verification (up to ${ACTIVATION_TIMEOUT_SECONDS}s before resend)...
[domo] ============================================================
EOF

    push_activation_dashboard_row "You" pending "$display_code" "$send_to" true

    local redeem rc token chat_uid
    set +e
    redeem="$(poll_activation_redeem "$activation_secret")"
    rc=$?
    set -e
    if [[ "$rc" -eq 0 ]]; then
      token="$(printf '%s' "$redeem" | json_value token)"
      chat_uid="$(printf '%s' "$redeem" | json_value chat.uid)"
      [[ -n "$token" ]] || die "verified redeem response had no token."
      [[ -n "$chat_uid" ]] || die "verified redeem response had no chat.uid."

      write_plow_channel_state_file "$token" "$chat_uid"
      complete_activation "$chat_uid" solo
      return 0
    fi
    [[ "$rc" -eq 75 ]] || return "$rc"
    resend_count=$((resend_count + 1))
    log "Activation code not received — re-issuing a fresh solo activation code."
    [[ "$ACTIVATION_MAX_RESENDS" -eq 0 || "$resend_count" -le "$ACTIVATION_MAX_RESENDS" ]] \
      || die "activation code still not received after resend; re-run './domo activate' to resend."
  done
}

group_members_json() {
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    let o = {};
    try { o = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8")); } catch {}
    const members = Array.isArray(o?.interview?.members) ? o.interview.members : [];
    process.stdout.write(JSON.stringify(members.filter((m) => typeof m === "string" && m.trim()).map((m) => m.trim())));
  '
}

group_activation_detail_exists() {
  [[ -f "$INSTALL_STATE_FILE" ]] || return 1
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    try {
      const o = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
      const d = o.activation_detail;
      process.exit(d?.mode === "group" && d?.token && d?.chat?.uid ? 0 : 1);
    } catch {
      process.exit(1);
    }
  '
}

plow_get_primary_line() {
  local token="$1" lines
  lines="$(plow_http_json GET /v1/lines "" "$token")"
  printf '%s' "$lines" | bun -e '
    const fs = require("fs");
    const o = JSON.parse(fs.readFileSync(0, "utf8"));
    const line = Array.isArray(o.data) ? o.data[0] : null;
    if (!line?.uid || !line?.provider_key) {
      console.error("GET /v1/lines returned no usable line with uid/provider_key");
      process.exit(2);
    }
    process.stdout.write(JSON.stringify(line));
  '
}

group_chat_payload() {
  local line_id="$1" members_json="$2"
  LINE_ID="$line_id" MEMBERS_JSON="$members_json" bun -e '
    const members = JSON.parse(process.env.MEMBERS_JSON || "[]");
    if (!Array.isArray(members) || members.length === 0) {
      console.error("group activation requires at least one member in install-state.json");
      process.exit(2);
    }
    process.stdout.write(JSON.stringify({
      participants: [
        { type: "agent", line_id: process.env.LINE_ID },
        ...members.map((display_name) => ({ type: "member", display_name })),
      ],
    }));
  '
}

plow_create_group_chat() {
  local token="$1" line_id="$2" members_json="$3" payload
  payload="$(group_chat_payload "$line_id" "$members_json")"
  plow_http_json POST /v1/chats "$payload" "$token"
}

plow_resend_group_invitation() {
  local token="$1" chat_uid="$2" participant_uid="$3"
  plow_http_json POST "/v1/chats/$chat_uid/invitations/$participant_uid/resend" "" "$token"
}

persist_group_activation_detail() {
  local token="$1" owner_json="$2" line_json="$3" chat_json="$4"
  local owner_file line_file chat_file tmp
  owner_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-owner.XXXXXX")"
  line_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-line.XXXXXX")"
  chat_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-chat.XXXXXX")"
  printf '%s' "$owner_json" > "$owner_file"
  printf '%s' "$line_json" > "$line_file"
  printf '%s' "$chat_json" > "$chat_file"
  tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" TOKEN="$token" BASE_URL="$PLOW_BASE_URL" bun -e '
    const fs = require("fs");
    const [out, ownerFile, lineFile, chatFile] = process.argv.slice(1);
    let state = {};
    if (fs.existsSync(process.env.INSTALL_STATE_FILE)) {
      state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    }
    state.interview = state.interview && typeof state.interview === "object"
      ? { ...state.interview, status: state.interview.status ?? (state.interview.mode ? "collected" : "pending"), members: state.interview.members ?? [] }
      : { status: "pending", members: [] };
    state.login = state.login || "pending";
    state.calendar = state.calendar || "pending";
    state.build = state.build || "pending";
    state.ready = state.ready || false;
    const owner = JSON.parse(fs.readFileSync(ownerFile, "utf8"));
    const line = JSON.parse(fs.readFileSync(lineFile, "utf8"));
    const chat = JSON.parse(fs.readFileSync(chatFile, "utf8"));
    const members = (chat.participants || [])
      .filter((p) => p.type === "member")
      .map((p) => ({
        uid: p.uid,
        display_name: p.display_name,
        status: p.status === "active" ? "verified" : "pending",
        verification_code: p.verification_code,
        provider_key: chat.provider_key || line.provider_key,
      }));
    state.activation = state.activation || "pending";
    state.activation_detail = {
      mode: "group",
      base_url: process.env.BASE_URL.replace(/\/$/, ""),
      owner: {
        status: "verified",
        activation_secret: owner.activation_secret,
        display_code: owner.display_code,
        send_to: owner.send_to,
        line_uid: owner.line_id ?? owner.line_uid ?? line.uid,
      },
      token: process.env.TOKEN,
      line,
      chat,
      participants: members,
      owner_redeemed: true,
      chat_active: chat.status === "active",
    };
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp" "$owner_file" "$line_file" "$chat_file"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
  rm -f "$owner_file" "$line_file" "$chat_file"
}

update_group_participant_status() {
  local participant_uid="$1" status="$2" provider_key="${3:-}"
  local tmp; tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" PARTICIPANT_UID="$participant_uid" STATUS="$status" PROVIDER_KEY="$provider_key" bun -e '
    const fs = require("fs");
    const out = process.argv.slice(1)[0];
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    const detail = state.activation_detail || {};
    for (const p of detail.participants || []) {
      if (p.uid === process.env.PARTICIPANT_UID) {
        p.status = process.env.STATUS;
        if (process.env.PROVIDER_KEY) p.verified_provider_key = process.env.PROVIDER_KEY;
      }
    }
    for (const p of detail.chat?.participants || []) {
      if (p.uid === process.env.PARTICIPANT_UID) {
        p.status = process.env.STATUS === "verified" ? "active" : p.status;
        if (process.env.PROVIDER_KEY) p.provider_key = process.env.PROVIDER_KEY;
      }
    }
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
}

update_group_participant_code() {
  local participant_json="$1"
  local participant_file tmp
  participant_file="$(umask 077; mktemp "${TMPDIR:-/tmp}/domo-resend-participant.XXXXXX")"
  printf '%s' "$participant_json" > "$participant_file"
  tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const [out, participantFile] = process.argv.slice(1);
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    const updated = JSON.parse(fs.readFileSync(participantFile, "utf8"));
    const detail = state.activation_detail || {};
    for (const p of detail.participants || []) {
      if (p.uid === updated.uid) {
        p.status = updated.status === "active" ? "verified" : "pending";
        p.verification_code = updated.verification_code;
        p.verification_code_expires_at = updated.verification_code_expires_at;
      }
    }
    for (const p of detail.chat?.participants || []) {
      if (p.uid === updated.uid) {
        p.status = updated.status;
        p.verification_code = updated.verification_code;
        p.verification_code_expires_at = updated.verification_code_expires_at;
      }
    }
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp" "$participant_file"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
  rm -f "$participant_file"
}

pending_group_members() {
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    const pending = (state.activation_detail?.participants || [])
      .filter((p) => p.status !== "verified")
      .map((p) => p.display_name)
      .filter(Boolean);
    process.stdout.write(pending.join(", "));
  '
}

set_group_pending_message() {
  local pending="$1"
  local tmp; tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" PENDING_MEMBERS="$pending" bun -e '
    const fs = require("fs");
    const out = process.argv.slice(1)[0];
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    state.message = process.env.PENDING_MEMBERS
      ? `Waiting on household verification: ${process.env.PENDING_MEMBERS}`
      : "";
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
}

set_group_chat_active() {
  local tmp; tmp="$(umask 077; mktemp "$DOMO_HOME/.install-state.json.XXXXXX")"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const out = process.argv.slice(1)[0];
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    if (state.activation_detail) {
      state.activation_detail.chat_active = true;
      if (state.activation_detail.chat) state.activation_detail.chat.status = "active";
      for (const p of state.activation_detail.participants || []) p.status = "verified";
      for (const p of state.activation_detail.chat?.participants || []) {
        if (p.type === "member") p.status = "active";
      }
    }
    fs.writeFileSync(out, JSON.stringify(state, null, 2) + "\n");
  ' "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$INSTALL_STATE_FILE"
}

group_detail_field() {
  local path="$1"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" PATH_EXPR="$path" bun -e '
    const fs = require("fs");
    const state = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8"));
    let v = state.activation_detail;
    for (const part of process.env.PATH_EXPR.split(".")) v = v == null ? undefined : v[part];
    process.stdout.write(v == null ? "" : String(v));
  '
}

push_group_dashboard_from_detail() {
  _dash installer_step plow active "Activate Plow chat — verify household members"
  local owner_code owner_send
  owner_code="$(group_detail_field owner.display_code)"
  owner_send="$(group_detail_field owner.send_to)"
  push_activation_dashboard_row "Owner" verified "$owner_code" "$owner_send" true owner
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const d = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8")).activation_detail;
    for (const p of d.participants || []) {
      console.log([p.uid, p.display_name, p.status === "verified" ? "verified" : "pending", p.verification_code || "", p.provider_key || d.chat?.provider_key || d.line?.provider_key || ""].join("\t"));
    }
  ' | while IFS=$'\t' read -r uid name status code number; do
    push_activation_dashboard_row "$name" "$status" "$code" "$number" false "$uid"
  done
}

print_group_member_codes_from_detail() {
  local provider_key
  provider_key="$(group_detail_field line.provider_key)"
  [[ -n "$provider_key" ]] || provider_key="$(group_detail_field chat.provider_key)"
  cat >&2 <<EOF

[domo] ============================================================
[domo] HOUSEHOLD MEMBER VERIFICATION — ACTION REQUIRED
[domo] ============================================================
[domo] Each household member now texts their own VERIFY code to: $provider_key
EOF
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const d = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8")).activation_detail;
    for (const p of d.participants || []) console.error(`[domo]   ${p.display_name}: ${p.verification_code}`);
  '
  printf '[domo] ============================================================\n' >&2
}

reveal_group_member_codes() {
  push_group_dashboard_from_detail
  print_group_member_codes_from_detail
  local pending
  pending="$(pending_group_members)"
  set_group_pending_message "$pending"
  [[ -n "$pending" ]] && log "Waiting on household verification: $pending"
}

resend_pending_group_codes() {
  local token="$1" chat_uid="$2" initial_pending
  initial_pending="$(pending_group_members)"
  INSTALL_STATE_FILE="$INSTALL_STATE_FILE" bun -e '
    const fs = require("fs");
    const d = JSON.parse(fs.readFileSync(process.env.INSTALL_STATE_FILE, "utf8")).activation_detail;
    for (const p of d.participants || []) {
      if (p.status !== "verified") console.log([p.uid, p.display_name].join("\t"));
    }
  ' | while IFS=$'\t' read -r uid name; do
    [[ -n "$uid" ]] || continue
    local participant_json code number
    participant_json="$(plow_resend_group_invitation "$token" "$chat_uid" "$uid")"
    update_group_participant_code "$participant_json"
    code="$(printf '%s' "$participant_json" | json_value verification_code)"
    number="$(group_detail_field chat.provider_key)"
    [[ -n "$number" ]] || number="$(group_detail_field line.provider_key)"
    log "Re-issued verification code for ${name:-$uid}; text $code to $number."
  done
  push_group_dashboard_from_detail
  print_group_member_codes_from_detail
  local pending
  pending="$(pending_group_members)"
  set_group_pending_message "$pending"
  [[ -n "$initial_pending" ]] && log "Fresh group verification code(s) issued. Still waiting on: ${pending:-none}"
}

plow_ws_ticket() {
  local token="$1" chat_uid="$2" payload
  payload="$(CHAT_UID="$chat_uid" bun -e 'process.stdout.write(JSON.stringify({chat_id: process.env.CHAT_UID}))')"
  plow_http_json POST /v1/ws/ticket "$payload" "$token" | json_value ticket
}

ws_url_for_ticket() {
  local ticket="$1" base="${PLOW_BASE_URL%/}" scheme rest
  case "$base" in
    https://*) scheme="wss"; rest="${base#https://}" ;;
    http://*) scheme="ws"; rest="${base#http://}" ;;
    *) die "cannot derive websocket URL from PLOW_BASE_URL=$PLOW_BASE_URL" ;;
  esac
  printf '%s://%s/v1/ws?ticket=%s' "$scheme" "$rest" "$ticket"
}

plow_ws_listen_once() {
  local ws_url="$1"
  WS_URL="$ws_url" DOMO_WS_TIMEOUT_MS="$WS_TIMEOUT_MS" bun -e '
    const ws = new WebSocket(process.env.WS_URL);
    let sawActive = false;
    let opened = false;
    let timedOut = false;
    const timeout = setTimeout(() => {
      timedOut = true;
      console.error("timed out waiting for Plow websocket frames");
      try { ws.close(); } catch {}
      process.exit(68);
    }, Number(process.env.DOMO_WS_TIMEOUT_MS || 300000));
    ws.addEventListener("open", () => { opened = true; });
    ws.addEventListener("message", (event) => {
      const text = String(event.data);
      console.log(text);
      try {
        if (JSON.parse(text).type === "chat_active") sawActive = true;
      } catch {}
      if (sawActive) ws.close();
    });
    ws.addEventListener("close", () => {
      clearTimeout(timeout);
      process.exit(sawActive ? 0 : timedOut ? 68 : opened ? 66 : 67);
    });
    ws.addEventListener("error", () => {
      clearTimeout(timeout);
      process.exit(67);
    });
  '
}

handle_group_ws_frame() {
  local frame="$1" type
  type="$(printf '%s' "$frame" | json_value type)"
  case "$type" in
    participant_verified)
      local uid name provider
      uid="$(printf '%s' "$frame" | json_value participant.uid)"
      name="$(printf '%s' "$frame" | json_value participant.display_name)"
      provider="$(printf '%s' "$frame" | json_value participant.provider_key)"
      [[ -n "$uid" ]] || die "participant_verified frame missing participant.uid"
      update_group_participant_status "$uid" verified "$provider"
      [[ -n "$name" ]] && mark_activation_dashboard_verified "$name" "$uid"
      local pending
      pending="$(pending_group_members)"
      set_group_pending_message "$pending"
      [[ -n "$pending" ]] && log "Still waiting on household verification: $pending"
      ;;
    connected)
      return 11
      ;;
    chat_active)
      set_group_chat_active
      set_group_pending_message ""
      push_group_dashboard_from_detail
      return 10
      ;;
    *)
      log "Ignoring Plow websocket frame type '${type:-unknown}'."
      ;;
  esac
  return 0
}

listen_group_until_chat_active() {
  local token="$1" chat_uid="$2" reconnects=0 resend_count=0
  local revealed=0
  while :; do
    local ticket ws_url fifo pid rc active=0
    ticket="$(plow_ws_ticket "$token" "$chat_uid")"
    [[ -n "$ticket" ]] || die "POST /v1/ws/ticket returned no ticket."
    ws_url="$(ws_url_for_ticket "$ticket")"
    fifo="$(mktemp -u "${TMPDIR:-/tmp}/domo-ws.XXXXXX")"
    mkfifo "$fifo"
    plow_ws_listen_once "$ws_url" > "$fifo" &
    pid=$!
    while IFS= read -r frame; do
      local hrc=0
      handle_group_ws_frame "$frame" || hrc=$?
      case "$hrc" in
        0) ;;
        10) active=1 ;;
        11)
          if [[ "$revealed" -eq 0 ]]; then
            reveal_group_member_codes
            revealed=1
          fi
          ;;
        *) die "unexpected group websocket handler status $hrc" ;;
      esac
    done < "$fifo"
    set +e
    wait "$pid"
    rc=$?
    set -e
    rm -f "$fifo"
    [[ "$active" -eq 1 ]] && return 0
    if [[ "$rc" -eq 68 ]]; then
      resend_count=$((resend_count + 1))
      log "No member verification received before timeout — offering resend for pending household members."
      [[ "$ACTIVATION_MAX_RESENDS" -eq 0 || "$resend_count" -le "$ACTIVATION_MAX_RESENDS" ]] \
        || die "group verification codes still not received after resend; retry './domo activate' to resend."
      resend_pending_group_codes "$token" "$chat_uid"
      continue
    fi
    if [[ "$reconnects" -lt 1 ]]; then
      reconnects=$((reconnects + 1))
      log "Plow websocket dropped before chat_active; reconnecting once after backoff."
      _dash installer_step plow active "Plow chat verification reconnecting..."
      sleep 2
    else
      die "Plow websocket dropped after one reconnect before chat_active; retry './domo activate'."
    fi
    [[ "$rc" -eq 0 ]] && sleep 1
  done
}

start_group_activation() {
  local members_json response activation_secret display_code send_to line_id redeem token line_json chat_json chat_uid
  members_json="$(group_members_json)"
  [[ "$(MEMBERS_JSON="$members_json" bun -e 'process.stdout.write(String(JSON.parse(process.env.MEMBERS_JSON).length))')" -gt 0 ]] \
    || die "group activation requires at least one member in $INSTALL_STATE_FILE."

  local owner_resend_count=0
  while :; do
    log "Requesting Plow owner activation at $PLOW_BASE_URL ..."
    response="$(plow_auth_activate '{"name":"Domo"}')" \
      || die "activation request failed (POST /v1/auth/activate). Check connectivity."
    activation_secret="$(printf '%s' "$response" | json_value activation_secret)"
    display_code="$(printf '%s' "$response" | json_value display_code)"
    send_to="$(printf '%s' "$response" | json_value send_to)"
    line_id="$(printf '%s' "$response" | bun -e 'const o=JSON.parse(require("fs").readFileSync(0,"utf8"));process.stdout.write(String(o.line_id??o.line_uid??""))')"
    [[ -n "$activation_secret" ]] || die "activation response missing activation_secret."
    [[ -n "$display_code" && -n "$send_to" ]] || die "activation response missing display_code/send_to."
    write_activation_state_file "$response"
    persist_group_owner_activation_detail "$response" pending

    cat >&2 <<EOF

[domo] ============================================================
[domo] PLOW OWNER ACTIVATION — ACTION REQUIRED
[domo] ============================================================
[domo] First, from the installer phone, text EXACTLY:
[domo]
[domo]     $display_code
[domo]
[domo]   to:  $send_to
[domo]
[domo] (line: ${line_id:-unknown})  Polling for owner verification (up to ${ACTIVATION_TIMEOUT_SECONDS}s before resend)...
[domo] ============================================================
EOF
    push_activation_dashboard_row "Owner" pending "$display_code" "$send_to" true owner

    local rc
    set +e
    redeem="$(poll_activation_redeem "$activation_secret")"
    rc=$?
    set -e
    if [[ "$rc" -eq 0 ]]; then
      token="$(printf '%s' "$redeem" | json_value token)"
      [[ -n "$token" ]] || die "verified redeem response had no token."
      persist_group_owner_activation_detail "$response" verified
      push_activation_dashboard_row "Owner" verified "$display_code" "$send_to" true owner
      break
    fi
    [[ "$rc" -eq 75 ]] || return "$rc"
    owner_resend_count=$((owner_resend_count + 1))
    log "Owner activation code not received — re-issuing a fresh owner activation code."
    [[ "$ACTIVATION_MAX_RESENDS" -eq 0 || "$owner_resend_count" -le "$ACTIVATION_MAX_RESENDS" ]] \
      || die "owner activation code still not received after resend; re-run './domo activate' to resend."
  done

  line_json="$(plow_get_primary_line "$token")"
  line_id="$(printf '%s' "$line_json" | json_value uid)"
  chat_json="$(plow_create_group_chat "$token" "$line_id" "$members_json")"
  chat_uid="$(printf '%s' "$chat_json" | json_value uid)"
  [[ -n "$chat_uid" ]] || die "POST /v1/chats response missing chat uid."

  persist_group_activation_detail "$token" "$response" "$line_json" "$chat_json"
}

activate_group_path() {
  if group_activation_detail_exists; then
    log "Resuming group activation from $INSTALL_STATE_FILE:activation_detail."
  else
    start_group_activation
  fi

  local token chat_uid
  token="$(group_detail_field token)"
  chat_uid="$(group_detail_field chat.uid)"
  [[ -n "$token" && -n "$chat_uid" ]] || die "activation_detail missing token/chat.uid; cannot resume group activation."
  listen_group_until_chat_active "$token" "$chat_uid"
  write_plow_channel_state_file "$token" "$chat_uid"
  complete_activation "$chat_uid" group
}

cmd_activate() {
  local force=0 mode
  [[ "${1:-}" == "--force" ]] && force=1
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] || die "activate is only for DOMO_CHANNEL=plow-chat (current: $DOMO_CHANNEL)."
  require_curl
  require_bun

  mkdir -p "$PLOW_DIR"; chmod 700 "$PLOW_DIR"

  if [[ "$force" -eq 0 && -f "$PLOW_STATE_FILE" ]]; then
    local existing; existing="$(json_get "$PLOW_STATE_FILE" "token")"
    if [[ -n "$existing" ]]; then
      log "already activated (state.json has a token). Use './domo activate --force' to redo."
      return 0
    fi
  fi

  mode="$(activation_mode)"
  case "$mode" in
    solo) activate_solo_path ;;
    group) activate_group_path ;;
    *) die "unknown install interview mode '$mode' in $INSTALL_STATE_FILE (expected solo or group)." ;;
  esac
}

# ---------------------------------------------------------------------------
# exec_interactive_session — the FOREGROUND interactive launch shared by `shell`
# and `login`: isolate the config dir, resolve auth, cd into $WORKSPACE (so the
# project-dir slug is right), build the pinned-session argv, and exec an
# interactive TTY claude. Same argv as `start`, so all three share ONE session.
# ---------------------------------------------------------------------------
exec_interactive_session() {
  export_config_dir
  require_claude
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] && require_bun
  ensure_auth
  [[ -d "$WORKSPACE" ]] || mkdir -p "$WORKSPACE"
  cd "$WORKSPACE" # cd BEFORE building argv so the workspace project-dir slug is correct
  build_claude_argv
  log "Launch: ${CLAUDE_ARGV[*]}"
  exec "${CLAUDE_ARGV[@]}"
}

# ---------------------------------------------------------------------------
# shell — FOREGROUND interactive session (one-time consent / /login / debugging).
# Uses the SAME launch argv as start so they share ONE pinned session.
# ---------------------------------------------------------------------------
cmd_shell() {
  log "Opening FOREGROUND session in $WORKSPACE (CLAUDE_CONFIG_DIR=$CONFIG_DIR)."
  log "One-time here: accept channels-preview consent + '/login'. Then exit."
  exec_interactive_session
}

# ---------------------------------------------------------------------------
# login — sign in to the Claude subscription for THIS isolated config dir. A fresh
# config home makes Claude auto-run first-run onboarding on boot (theme picker, then
# the login wall); we pass "/quit" as the initial slash command so Claude exits on
# its own once the user finishes theme + browser login — no "now type /login" step,
# no Ctrl+C. Authenticates the config dir only; starts no channel/session. This is
# the real copy-paste command the installer hands over.
# ---------------------------------------------------------------------------
cmd_login() {
  export_config_dir
  require_claude
  # Subscription auth only — never let a metered key shadow the interactive login.
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    warn "ANTHROPIC_API_KEY is set; unsetting it so /login uses subscription auth."
    unset ANTHROPIC_API_KEY
  fi
  [[ -d "$WORKSPACE" ]] || mkdir -p "$WORKSPACE"
  cd "$WORKSPACE"
  log "Signing in to your Claude subscription (CLAUDE_CONFIG_DIR=$CONFIG_DIR)."
  log "Claude opens now: pick a theme + complete the browser login — then it exits on its own (no Ctrl+C)."
  # A fresh config auto-runs onboarding (theme, then the login wall) on boot; the
  # "/quit" initial command makes Claude exit once those finish — so the user isn't
  # left in an interactive session. (Already-onboarded+authed → harmless boot+exit.)
  exec claude "/quit"
}

# Compute a pkill -f pattern that uniquely identifies THIS instance's claude
# process. The pinned session UUID is the tightest signature — it appears in the
# argv as `--session-id <uuid>` / `--resume <uuid>` and is unique per instance, so
# two Domo instances under different DOMO_HOME never reap each other. If no pinned
# UUID exists, fall back to the workspace path: it is conservative and instance
# scoped, unlike the generic channel name.
daemon_kill_pattern() {
  local sid; sid="$(read_session_id)"
  if [[ -n "$sid" ]]; then printf '%s' "$sid"; return; fi
  printf '%s' "$WORKSPACE"
}

# Persist the kill pattern at start so stop can reap the real claude even if the
# recorded PID is the `script` wrapper.
write_daemon_sig() {
  mkdir -p "$RUN_DIR"
  local tmp; tmp="$(umask 077; mktemp "$RUN_DIR/.domo.sig.XXXXXX")"
  printf '%s\n' "$(daemon_kill_pattern)" > "$tmp"
  mv -f "$tmp" "$SIG_FILE"
}

# ---------------------------------------------------------------------------
# start — BACKGROUND detached daemon. Same session as shell. PID file + logfile.
#
# ⚠️ HEADLESS-SURVIVAL (verify-at-runtime): an interactive `claude --channels` may
# exit on stdin EOF when backgrounded. macOS has NO setsid (verified), but `script`
# IS at /usr/bin/script. So we give claude a controlling PTY via:
#     script -q -F -e /dev/null claude … </dev/null >>LOG 2>&1 &
# (-q quiet, -F flush so logs stream, -e pass through child exit status; file arg is
# /dev/null so no typescript is kept; the rest is the command). This needs no tmux.
# VERIFY at runtime that the session stays alive after the launching shell exits and
# that channel events still flow; if `script` mishandles it, fall back to a
# foreground `./domo shell` under a user-run tmux / launchd KeepAlive. Documented,
# not blocking. Override the wrapper entirely with DOMO_NO_PTY=1 (plain background).
# ---------------------------------------------------------------------------
cmd_start() {
  export_config_dir
  require_claude
  [[ "$DOMO_CHANNEL" == "plow-chat" ]] && require_bun
  ensure_auth

  [[ -d "$WORKSPACE" ]] || die "workspace not found at $WORKSPACE. Run './domo setup' first."

  # Refuse if a live daemon is already recorded. Check BOTH the recorded pid AND
  # the scoped argv signature: under the PTY path the wrapper pid may have exited
  # while the orphaned claude survives (#1), so a pid-only check would wrongly
  # allow a second claude. We must cd into WORKSPACE-independent scope here, so
  # compute the signature directly.
  local sig; sig="$(daemon_kill_pattern)"
  if [[ -f "$PID_FILE" ]]; then
    local oldpid; oldpid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
      die "daemon already running (pid $oldpid). Use './domo stop' first, or './domo logs'."
    fi
    warn "stale pid file (pid not alive); overwriting."
    rm -f "$PID_FILE"
  fi
  if [[ -n "$sig" ]] && pgrep -f -- "$sig" >/dev/null 2>&1; then
    die "a claude process matching this instance is already running (orphaned wrapper?). Run './domo stop' first."
  fi

  mkdir -p "$RUN_DIR"
  cd "$WORKSPACE" # cd BEFORE building argv so the workspace project-dir slug is correct
  build_claude_argv

  log "Starting BACKGROUND daemon in $WORKSPACE"
  log "Launch: ${CLAUDE_ARGV[*]}"
  log "Logfile: $LOG_FILE"

  {
    printf '\n===== domo start %s =====\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'channel=%s  permission=%s  argv=%s\n' "$DOMO_CHANNEL" "$PERMISSION_MODE" "${CLAUDE_ARGV[*]}"
  } >>"$LOG_FILE" 2>&1

  # A custom (development) channel shows a confirmation TUI on EVERY launch that a
  # backgrounded daemon can't answer. Detect the dev-channels flag and, if present,
  # drive the launch through expect (answers the prompt + keeps the session alive).
  local needs_confirm=0 a
  for a in "${CLAUDE_ARGV[@]}"; do
    [[ "$a" == "--dangerously-load-development-channels" ]] && needs_confirm=1
  done

  if [[ "${DOMO_NO_PTY:-0}" == "1" ]]; then
    # Plain detached background (verify-at-runtime: may exit on stdin EOF).
    # No PTY wrapper, so the recorded pid IS the claude process — stop can TERM it
    # directly and there is no orphaned child. (Won't answer a dev-channels prompt.)
    nohup "${CLAUDE_ARGV[@]}" </dev/null >>"$LOG_FILE" 2>&1 &
  elif [[ "$needs_confirm" == "1" ]] && command -v expect >/dev/null 2>&1; then
    # expect gives claude a PTY, sends Enter on the dev-channels confirmation, then
    # keeps the session alive. The recorded pid is the expect wrapper; its argv
    # carries the same session UUID, so stop's signature pkill reaps wrapper + claude.
    log "Driving the dev-channels confirmation via expect."
    nohup expect -f "$SPAWN_CONFIRM" "${CLAUDE_ARGV[@]}" </dev/null >>"$LOG_FILE" 2>&1 &
  else
    [[ "$needs_confirm" == "1" ]] && warn "expect not found — the dev-channels confirmation will hang the daemon. Install expect, or run './domo shell'."
    # PTY-wrapped via macOS `script` so claude sees a controlling tty (no stdin EOF).
    # ⚠️ The recorded pid here is the `script` WRAPPER, not claude. On macOS the
    # PTY child (claude) runs in its OWN process group / session, so killing the
    # wrapper does NOT reap claude (verified: it orphans + survives). `stop` MUST
    # therefore tree-kill (see cmd_stop): it kills the wrapper AND pkills the exact
    # claude argv signature scoped to this repo. We persist that signature here.
    nohup script -q -F -e /dev/null "${CLAUDE_ARGV[@]}" </dev/null >>"$LOG_FILE" 2>&1 &
  fi
  # `disown` takes a JOB SPEC, not a PID, and bash 3.2 errors on a numeric arg.
  # `nohup` already detaches from SIGHUP, so disowning the current job (%%) is
  # belt-and-suspenders only and is allowed to no-op.
  disown %% 2>/dev/null || true
  local pid=$!
  printf '%s\n' "$pid" > "$PID_FILE"

  # Record the resolved claude argv signature so `stop` can reap the real claude
  # process even when `pid` is the `script` wrapper (PTY path). Scoped to THIS
  # repo via the workspace path + session flag so we never touch unrelated procs.
  write_daemon_sig

  # Brief liveness check so an immediate crash is reported now, not silently.
  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$PID_FILE" "$SIG_FILE"
    die "daemon exited immediately — see $LOG_FILE (last lines below):
$(tail -n 20 "$LOG_FILE" 2>/dev/null | strip_ansi || true)"
  fi
  log "Daemon process up (pid $pid)."

  # Readiness probe. A live pid is NOT proof Domo works: on a fresh/un-onboarded
  # config, claude parks in first-run onboarding (theme picker, then the /login
  # wall) and the channel never spawns — the pid stays alive, but no session
  # transcript is written and no channel connects. Wait for a real readiness
  # signal (the pinned-session jsonl appears, or the channel logs that it's
  # listening) before declaring success.
  local sid jsonl ready=0 i
  sid="$(read_session_id)"
  jsonl="$PROJECTS_DIR/$sid.jsonl"
  for i in $(seq 1 15); do
    if { [[ -n "$sid" ]] && [[ -f "$jsonl" ]]; } || grep -qiE 'Listening for channel|channel messages from' "$LOG_FILE" 2>/dev/null; then
      ready=1; break
    fi
    kill -0 "$pid" 2>/dev/null || break
    sleep 1
  done
  if [[ "$ready" -eq 1 ]]; then
    log "Daemon ready — channel listening. Transcript feed: ./domo logs    Stop with: ./domo stop"
  else
    warn "Daemon pid is alive but NOT ready after ~15s: no session transcript and no channel yet."
    warn "Most likely '$CONFIG_DIR' hasn't completed first-run onboarding/login, so claude is parked"
    warn "at the theme picker or the /login wall. Run './domo stop', then './domo login' and complete"
    warn "the theme picker + '/login' in a real terminal, then './domo start' again."
    warn "('./domo logs --raw' shows where it's parked.)"
  fi
}

# ---------------------------------------------------------------------------
# stop — kill the daemon by PID (TERM, wait, KILL) + sweep stray channel child.
# ---------------------------------------------------------------------------
cmd_stop() {
  local pid=""
  if [[ -f "$PID_FILE" ]]; then
    pid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
  fi

  if [[ -z "$pid" ]]; then
    log "not running (no pid file)."
  elif kill -0 "$pid" 2>/dev/null; then
    log "Stopping daemon (pid $pid)..."
    kill -TERM "$pid" 2>/dev/null || true
    local i=0
    while kill -0 "$pid" 2>/dev/null && [[ "$i" -lt 10 ]]; do sleep 0.5; i=$((i+1)); done
    if kill -0 "$pid" 2>/dev/null; then
      warn "did not exit on TERM; sending KILL."
      kill -KILL "$pid" 2>/dev/null || true
    fi
    log "Wrapper process stopped."
  else
    log "pid $pid not alive; cleaning up."
  fi

  # TREE-KILL the real claude process (#1): under the PTY path the recorded pid is
  # the `script` wrapper, whose child claude runs in a separate session and is
  # ORPHANED (not reaped) when the wrapper dies. We reap it by its recorded argv
  # signature, scoped to THIS instance. (Under DOMO_NO_PTY=1 the pid above already
  # IS claude, so this is a harmless no-op.)
  local sig=""
  if [[ -f "$SIG_FILE" ]]; then
    sig="$(tr -d '\n' < "$SIG_FILE" 2>/dev/null || true)"
  fi
  [[ -n "$sig" ]] || sig="$(daemon_kill_pattern)"
  if [[ -n "$sig" ]]; then
    # Match the claude argv (not the channel server.ts) by the scoped signature.
    if pgrep -f -- "$sig" >/dev/null 2>&1; then
      warn "Reaping claude process(es) matching scoped signature."
      pkill -TERM -f -- "$sig" 2>/dev/null || true
      local j=0
      while pgrep -f -- "$sig" >/dev/null 2>&1 && [[ "$j" -lt 10 ]]; do sleep 0.5; j=$((j+1)); done
      if pgrep -f -- "$sig" >/dev/null 2>&1; then
        warn "claude did not exit on TERM; sending KILL."
        pkill -KILL -f -- "$sig" 2>/dev/null || true
      fi
    fi
  fi

  rm -f "$PID_FILE" "$SIG_FILE"

  # Sweep stray channel children scoped to THIS repo path so we never touch
  # unrelated processes (the channel server is a separate child of claude).
  case "$DOMO_CHANNEL" in
    plow-chat)
      # The channel server is spawned as `bun run --cwd $PLOW_CHANNEL_DIR … start`,
      # so its argv contains the channel dir path — match on that (repo-scoped).
      if pgrep -f "$PLOW_CHANNEL_DIR" >/dev/null 2>&1; then
        warn "Sweeping stray plow-chat channel server(s)."
        pkill -f "$PLOW_CHANNEL_DIR" 2>/dev/null || true
      fi
      ;;
  esac
  log "Daemon stopped."
}

# ---------------------------------------------------------------------------
# reset — full, idempotent teardown for one DOMO_HOME.
# Order matters: Plow cleanup and Claude logout need files inside DOMO_HOME, so
# the local tree is removed only after the external state has been handled.
# ---------------------------------------------------------------------------
safe_remove_domo_home() {
  local target="${DOMO_HOME%/}"
  [[ -n "$target" ]] || die "DOMO_HOME resolved to an empty path; refusing to reset."
  [[ "$target" != "/" ]] || die "DOMO_HOME is /; refusing to reset."
  [[ "$target" != "$HOME" ]] || die "DOMO_HOME is HOME; refusing to reset."

  if [[ -e "$target" ]]; then
    local target_abs repo_abs
    target_abs="$(cd "$target" && pwd -P)"
    repo_abs="$(cd "$REPO_ROOT" && pwd -P)"
    case "$repo_abs" in
      "$target_abs"|"$target_abs"/*) die "DOMO_HOME contains this checkout ($repo_abs); refusing to remove $target_abs." ;;
    esac
    rm -rf -- "$target"
    [[ ! -e "$target" ]] || die "failed to remove DOMO_HOME=$target"
    log "Removed DOMO_HOME=$target"
  else
    log "DOMO_HOME already absent: $target"
  fi
}

cmd_reset() {
  export_config_dir
  log "Resetting Domo instance at DOMO_HOME=$DOMO_HOME"

  if [[ ! -d "$DOMO_HOME" ]]; then
    log "DOMO_HOME already absent; no local daemon metadata or state to tear down."
    safe_remove_domo_home
    log "Reset complete."
    return 0
  fi

  local rc
  log "Step 1/4: stopping daemon(s)."
  set +e
  cmd_stop
  rc=$?
  set -e
  [[ "$rc" -eq 0 ]] || die "main daemon stop failed with rc=$rc"

  # Older piece-based installs used domo-ready.{pid,sig,tmux}; keep reset able to
  # tear those down too while the CLI consolidates.
  if [[ -x "$READY_PIECE" ]]; then
    set +e
    DOMO_HOME="$DOMO_HOME" "$READY_PIECE" stop
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || die "ready-piece daemon stop failed with rc=$rc"
  else
    warn "ready-piece stop unavailable at $READY_PIECE"
  fi

  log "Step 2/4: deleting Plow chat."
  if [[ -f "$PLOW_STATE_FILE" ]]; then
    [[ -x "$ACTIVATE_PIECE" ]] || die "activate cleanup piece missing or not executable: $ACTIVATE_PIECE"
    set +e
    DOMO_HOME="$DOMO_HOME" "$ACTIVATE_PIECE" cleanup
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || die "Plow chat cleanup failed with rc=$rc; leaving DOMO_HOME intact for retry."
  else
    log "No Plow state file to clean up: $PLOW_STATE_FILE"
  fi

  log "Step 3/4: logging out Claude auth for this isolated config."
  if [[ -d "$CONFIG_DIR" ]]; then
    [[ -x "$LOGIN_PIECE" ]] || die "login logout piece missing or not executable: $LOGIN_PIECE"
    local logout_rc status_out status_rc
    set +e
    DOMO_HOME="$DOMO_HOME" "$LOGIN_PIECE" logout
    logout_rc=$?
    set -e
    [[ "$logout_rc" -eq 0 ]] || warn "Claude auth logout returned rc=$logout_rc; checking auth status before deciding."

    set +e
    status_out="$(DOMO_HOME="$DOMO_HOME" "$LOGIN_PIECE" status 2>&1)"
    status_rc=$?
    set -e
    printf '%s\n' "$status_out" >&2
    if printf '%s\n' "$status_out" | grep -q 'loggedIn=false'; then
      log "Claude auth status confirmed loggedIn=false (status rc=$status_rc)."
    else
      die "Claude auth status did not confirm loggedIn=false after logout; leaving DOMO_HOME intact."
    fi
  else
    log "Claude config dir already absent: $CONFIG_DIR"
  fi

  log "Step 4/4: removing local state tree."
  safe_remove_domo_home
  log "Reset complete."
}

# ---------------------------------------------------------------------------
# status — resolved config + daemon liveness + channel state (no secrets).
# With --assert, exit non-zero if anything required is missing (mirrors doctor).
# ---------------------------------------------------------------------------
cmd_status() {
  local assert=0
  [[ "${1:-}" == "--assert" ]] && assert=1
  export_config_dir
  local ok=0

  local sid; sid="$(read_session_id)"
  log "CONFIG_DIR:      $CONFIG_DIR"
  log "WORKSPACE:       $WORKSPACE"
  log "DOMO_CHANNEL:    $DOMO_CHANNEL"
  log "session_id:      ${sid:-<none>}"
  log "permission mode: $PERMISSION_MODE"
  case "$DOMO_CHANNEL" in
    plow-chat) log "channel flag:    --dangerously-load-development-channels server:plow-chat"; log "channel dir:     $PLOW_CHANNEL_DIR" ;;
    *) die "unknown DOMO_CHANNEL='$DOMO_CHANNEL' (expected plow-chat)." ;;
  esac

  # Session jsonl present? (first-run vs resume.)
  if [[ -n "$sid" && -f "$PROJECTS_DIR/$sid.jsonl" ]]; then
    log "session jsonl:   present ($PROJECTS_DIR/$sid.jsonl) -> resume"
  else
    log "session jsonl:   missing -> first run (--session-id)"
  fi

  # Daemon liveness.
  if [[ -f "$PID_FILE" ]]; then
    local pid; pid="$(tr -d '[:space:]' < "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      log "daemon:          ALIVE (pid $pid)"
    else
      warn "daemon:          DEAD (stale pid file: ${pid:-empty})"; ok=1
    fi
  else
    log "daemon:          not running (no pid file)"
  fi

  # Channel state (never print the token).
  case "$DOMO_CHANNEL" in
    plow-chat)
      local tok chat
      tok="$(json_get "$PLOW_STATE_FILE" "token")"
      chat="$(json_get "$PLOW_STATE_FILE" "chat_uid")"
      if [[ -n "$tok" && -n "$chat" ]]; then
        log "plow-chat state: present (token present, chat_uid $chat)"
        # Permission sanity (belt-and-suspenders).
        local perm; perm="$(stat -f '%Lp' "$PLOW_STATE_FILE" 2>/dev/null || true)"
        [[ "$perm" == "600" ]] || warn "plow-chat state.json perms are $perm (expected 600)."
      else
        warn "plow-chat state: missing — run './domo activate'"; ok=1
      fi
      ;;
    *) die "unknown DOMO_CHANNEL='$DOMO_CHANNEL' (expected plow-chat)." ;;
  esac

  if [[ "$assert" -eq 1 && "$ok" -ne 0 ]]; then
    die "status --assert: one or more required items missing (see WARNINGs)."
  fi
}

# resolve_transcript — path to the session transcript jsonl. Prefers the pinned
# session UUID; falls back to the newest jsonl by mtime under the project dir
# (covers the resume-spawned-a-new-file case). Empty if none exists yet.
resolve_transcript() {
  local sid tf
  sid="$(read_session_id)"
  tf="$PROJECTS_DIR/$sid.jsonl"
  if [[ -n "$sid" && -f "$tf" ]]; then printf '%s' "$tf"; return; fi
  ls -t "$PROJECTS_DIR"/*.jsonl 2>/dev/null | head -1
}

# tz_offset_seconds — local UTC offset in seconds (e.g. -25200 for PDT), so the
# transcript renderer can show wall-clock local time. 0 if undeterminable.
tz_offset_seconds() {
  local z sign hh mm off
  z="$(date +%z 2>/dev/null)" || { printf '0'; return; }
  [[ "$z" =~ ^[+-][0-9]{4}$ ]] || { printf '0'; return; }
  sign="${z:0:1}"; hh="${z:1:2}"; mm="${z:3:2}"
  off=$((10#$hh * 3600 + 10#$mm * 60)); [[ "$sign" == "-" ]] && off=$((-off))
  printf '%s' "$off"
}

# jq renderer: turn raw transcript jsonl lines into a readable conversation feed
# — 📥 inbound texts, 📤 outbound replies, ⚙ tool calls, 🤖 assistant notes.
# Read with -R so a malformed line is skipped (fromjson?) instead of aborting a
# live follow. Everything else (modes, attachments, tool_results) renders empty.
LOGS_JQ='
def clk($ts):
  ($ts // "") as $raw
  | ($raw | sub("\\.[0-9]+Z$";"Z")) as $c
  | (try ($c | fromdateiso8601 + $off | strftime("%m/%d %H:%M"))
     catch ($raw[5:16] | gsub("T";" ")));
(fromjson? // empty)
| (clk(.timestamp)) as $T
| if .type=="user" then
    (.message.content) as $c
    | if ($c|type)=="string" then
        if ($c|test("<channel")) then
          (($c|capture("user=\"(?<u>[^\"]*)\"")? | .u) // "You") as $who
          | ($c | capture("(?s)>(?<b>.*)</channel>") | .b
             | gsub("^\\s+|\\s+$";"") | gsub("\n";" ")) as $txt
          | "\($T)  📥 \($who): \($txt)"
        else "\($T)  ⌨️  \($c|gsub("\n";" ")|.[0:200])" end
      else empty end
  elif .type=="assistant" then
    ( .message.content[]?
      | if .type=="text" and (.text|length>0) then
          "\($T)  🤖 \(.text|gsub("\n";" "))"
        elif .type=="tool_use" then
          if (.name|test("reply$")) then
            "\($T)  📤 Domo: \((.input.text // .input.body // "")|gsub("\n";" "))"
          elif (.name|test("^(ToolSearch|Bash|Read|Glob|Grep|Edit|Write|TodoWrite|Task)$")) then empty
          else "\($T)  ⚙  \(.name|sub("^mcp__";"")|sub("^claude_ai_";"")|gsub("__";" · ")|gsub("_";" "))" end
        else empty end )
  else empty end
'

# ---------------------------------------------------------------------------
# logs — readable view of the session. Default renders the TRANSCRIPT jsonl
# (clean 📥/📤/⚙ conversation feed); --raw shows the PTY/TUI capture (escape-
# stripped) as a launch-debugging escape hatch. Follows by default; --no-follow
# prints once. Ctrl+C always exits cleanly (trap restores the terminal + reaps
# the tail child) — the raw TUI escapes are what used to make Ctrl+C appear dead.
# ---------------------------------------------------------------------------
cmd_logs() {
  local follow=1 raw=0 a
  for a in "$@"; do
    case "$a" in
      --no-follow|-n) follow=0 ;;
      --raw)          raw=1 ;;
      -h|--help)
        printf 'usage: domo logs [--raw] [--no-follow]\n  default: readable transcript feed   --raw: PTY/TUI capture (stripped)\n'
        return 0 ;;
      *) warn "logs: ignoring unknown arg '$a'" ;;
    esac
  done
  if [[ "$raw" -eq 0 ]] && ! command -v jq >/dev/null 2>&1; then
    warn "jq not found — showing the raw TUI log instead."
    raw=1
  fi

  # Restore the terminal on the way out (Ctrl+C included): stty sane + reset
  # SGR/cursor/alt-screen/bracketed-paste. Also guarantees the tail child is
  # reaped when you Ctrl+C out of follow mode.
  local restore='stty sane 2>/dev/null; printf "\033[0m\033[?25h\033[?1049l\033[?2004l\n" 2>/dev/null'

  # Pick the source + the renderer (a command array read from the source).
  local src; local renderer=()
  if [[ "$raw" -eq 1 ]]; then
    if [[ ! -f "$LOG_FILE" ]]; then log "no raw log yet; run './domo start'."; return 0; fi
    src="$LOG_FILE"; renderer=(strip_ansi)
  else
    src="$(resolve_transcript)"
    if [[ -z "$src" || ! -f "$src" ]]; then
      log "no transcript yet; run './domo start' and text the assistant."
      return 0
    fi
    local off; off="$(tz_offset_seconds)"
    renderer=(jq -rR --unbuffered --argjson off "$off" "$LOGS_JQ")
  fi

  if [[ "$follow" -eq 1 ]]; then
    trap "$restore; exit 0" INT TERM HUP
    tail -n 400 -f "$src" | "${renderer[@]}"
    eval "$restore"
    trap - INT TERM HUP
  elif [[ "$raw" -eq 1 ]]; then
    tail -n 200 "$src" | "${renderer[@]}"
  else
    "${renderer[@]}" "$src"   # full transcript, rendered once
  fi
}

# ---------------------------------------------------------------------------
# doctor — read-only preflight; non-zero exit on any failed assertion.
# ---------------------------------------------------------------------------
cmd_doctor() {
  export_config_dir
  local ok=0

  log "CONFIG_DIR:  $CONFIG_DIR"
  log "WORKSPACE:   $WORKSPACE"
  log "DOMO_CHANNEL: $DOMO_CHANNEL"

  if [[ -d "$WORKSPACE" ]]; then log "OK   workspace present"; else warn "MISS workspace absent (run './domo setup')"; ok=1; fi
  if command -v claude >/dev/null 2>&1; then log "OK   'claude' on PATH"; else warn "MISS 'claude' not on PATH"; ok=1; fi
  if command -v bun >/dev/null 2>&1; then log "OK   'bun' on PATH"; else warn "MISS 'bun' not on PATH (needed for plow-chat)"; [[ "$DOMO_CHANNEL" == "plow-chat" ]] && ok=1; fi

  # Auth: a headless token OR a real subscription login. File EXISTENCE is NOT
  # proof — on macOS the subscription OAuth lives in the Keychain (keyed per
  # config dir), and a `.credentials.json` may hold only MCP-server OAuth with no
  # `claudeAiOauth` block. So require the token, or the actual login block.
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]] || [[ -f "$ENV_FILE" ]] || [[ -f "$TOKEN_FILE" ]]; then
    log "OK   auth: token available (env or token file)"
  elif [[ -f "$CONFIG_DIR/.credentials.json" ]] && grep -q 'claudeAiOauth' "$CONFIG_DIR/.credentials.json" 2>/dev/null; then
    log "OK   auth: subscription login present in $CONFIG_DIR/.credentials.json"
  else
    log "INFO auth: not verifiable from token/file. On macOS the subscription login lives in the"
    log "     Keychain (a copied .credentials.json does NOT carry it). If '$CONFIG_DIR' has never"
    log "     completed '/login', run './domo login' in a real terminal first — 'start' verifies at runtime."
  fi

  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    warn "WARN ANTHROPIC_API_KEY is set — must be UNSET for subscription auth."; ok=1
  else
    log "OK   ANTHROPIC_API_KEY is unset"
  fi

  # Session UUID.
  local sid; sid="$(read_session_id)"
  if [[ -n "$sid" ]]; then log "OK   session_id present ($sid)"; else warn "MISS session_id absent (run './domo setup')"; ok=1; fi

  log "permission mode: $PERMISSION_MODE"

  # Channel-specific.
  case "$DOMO_CHANNEL" in
    plow-chat)
      log "channel flag: --dangerously-load-development-channels server:plow-chat (MCP server registered via 'claude mcp add')"
      local missing=0
      for f in "$PLOW_CHANNEL_DIR/.claude-plugin/plugin.json" "$PLOW_CHANNEL_DIR/.mcp.json" "$PLOW_CHANNEL_DIR/server.ts"; do
        if [[ -f "$f" ]]; then log "OK   channel file: $(basename "$f")"; else warn "MISS channel file: $f"; missing=1; ok=1; fi
      done
      local tok; tok="$(json_get "$PLOW_STATE_FILE" "token")"
      if [[ -n "$tok" ]]; then
        local perm; perm="$(stat -f '%Lp' "$PLOW_STATE_FILE" 2>/dev/null || true)"
        if [[ "$perm" == "600" ]]; then log "OK   plow-chat state.json present (chmod 600, token present)"; else warn "WARN plow-chat state.json perms $perm (expected 600)"; ok=1; fi
      else
        warn "WARN plow-chat state.json has no token — run './domo activate'"
      fi
      ;;
    *) die "unknown DOMO_CHANNEL='$DOMO_CHANNEL' (expected plow-chat)." ;;
  esac

  if [[ "$ok" -eq 0 ]]; then log "doctor: all checks passed."; else die "doctor: one or more checks failed (see WARNINGs)."; fi
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
usage() {
  cat >&2 <<EOF
Domo orchestrator

Usage: $(basename "$0") <command> [args]

Commands:
  setup            Idempotent bootstrap: isolated dirs + workspace + session UUID;
                   ensure the selected channel is loadable.
  activate [--force]
                   (plow-chat) Plow handshake in curl: print the code to text, poll
                   redeem, write the chmod-600 state file. --force re-activates.
  shell            FOREGROUND interactive session (one-time consent / /login / debug).
  login            Open the session so you can /login (sign in). Same as shell, with a hint.
  start            BACKGROUND detached daemon (PID file + logfile). Same pinned session.
  stop             Kill the daemon + sweep stray channel child.
  status [--assert] Resolved config + daemon liveness + channel state (no secrets).
  logs [--raw] [--no-follow]
                   Readable transcript feed (📥/📤/⚙). --raw = PTY/TUI capture.
  doctor           Read-only preflight; non-zero exit on any failed assertion.
  reset            Full teardown for this DOMO_HOME: stop daemon(s), delete the
                   Plow chat, logout Claude auth, then remove DOMO_HOME.

Environment:
  DOMO_CHANNEL            plow-chat (default)
  DOMO_HOME              base dir; default: $HOME/.domo
  DOMO_PERMISSION_MODE   permission mode; default 'auto'
  CLAUDE_CODE_OAUTH_TOKEN  optional headless subscription token
  PLOW_CHAT_BASE_URL     Plow API base for activate (default https://api.plow.co)
  DOMO_NO_PTY=1          start without the 'script' PTY wrapper (plain background)
  DOMO_SESSION_FALLBACK=1  use latest-jsonl-by-mtime resume instead of pinned UUID
EOF
}

main() {
  apply_env_policy
  local cmd="${1:-}"
  case "$cmd" in
    setup)    shift; cmd_setup "$@" ;;
    activate) shift; cmd_activate "$@" ;;
    shell)    shift; cmd_shell "$@" ;;
    login)    shift; cmd_login "$@" ;;
    start)    shift; cmd_start "$@" ;;
    stop)     shift; cmd_stop "$@" ;;
    status)   shift; cmd_status "$@" ;;
    logs)     shift; cmd_logs "$@" ;;
    doctor)   shift; cmd_doctor "$@" ;;
    reset)    shift; cmd_reset "$@" ;;
    ""|-h|--help|help) usage; [[ -z "$cmd" ]] && exit 1 || exit 0 ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

main "$@"
